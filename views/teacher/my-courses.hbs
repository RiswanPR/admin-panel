<div class="container-fluid">

    <!-- HEADER -->
    <div class="tc-hero mb-4">
        <div>
            <h2>My Courses</h2>
            <p>{{courses.length}} course(s) assigned to you</p>
        </div>
    </div>

    {{#if courses.length}}
    <div class="tc-grid">
        {{#each courses}}
        <div class="tc-card">

            <!-- Course Thumbnail -->
            <div class="tc-img-wrap">
                {{#if this.image}}
                <img src="{{this.imageUrl}}" alt="{{this.name}}" onerror="this.onerror=null;this.src='/img/placeholders/course-cover.svg'">
                {{else}}
                <div class="tc-img-placeholder">
                    <i class="fa-solid fa-layer-group"></i>
                </div>
                {{/if}}
                <div class="tc-badge">{{this.chapterCount}} Chapters</div>
            </div>

            <!-- Course Info -->
            <div class="tc-body">
                <h5 class="tc-title">{{this.name}}</h5>

                <div class="tc-meta">
                    <div class="tc-meta-item">
                        <i class="fa-solid fa-users"></i>
                        <span>{{this.studentCount}} students</span>
                    </div>
                    <div class="tc-meta-item">
                        <i class="fa-solid fa-calendar-alt"></i>
                        <span>{{this.lastUpdatedDisplay}}</span>
                    </div>
                </div>

                <!-- Actions -->
                <div class="tc-actions">
                    <a href="/teacher/courses/{{this._id}}" class="tc-btn-primary">
                        <i class="fa-solid fa-eye me-2"></i>View Course
                    </a>
                    <div class="tc-secondary-actions">
                        <a href="/teacher/courses/{{this._id}}" class="tc-btn-secondary" title="Manage Chapters">
                            <i class="fa-solid fa-book-open"></i>
                        </a>
                        <a href="/teacher/tstudents?course={{this._id}}" class="tc-btn-secondary" title="View Students">
                            <i class="fa-solid fa-users"></i>
                        </a>
                    </div>
                </div>

            </div>
        </div>
        {{/each}}
    </div>
    {{else}}
    <div class="tc-empty">
        <div class="tc-empty-icon"><i class="fa-solid fa-layer-group"></i></div>
        <h4>No Courses Assigned</h4>
        <p>Your administrator hasn't assigned any courses to you yet. Please contact your admin.</p>
    </div>
    {{/if}}

</div>


<style>
.tc-hero{
    background:linear-gradient(135deg,var(--brand),var(--brand-2));
    color:#fff;
    border-radius:22px;
    padding:30px 36px;
    display:flex;
    justify-content:space-between;
    align-items:center;
}
.tc-hero h2{ margin:0; font-weight:800; }
.tc-hero p{ margin:.4rem 0 0; opacity:.75; }

.tc-grid{
    display:grid;
    grid-template-columns:repeat(auto-fill,minmax(300px,1fr));
    gap:24px;
}

.tc-card{
    background:var(--surface);
    border-radius:22px;
    overflow:hidden;
    box-shadow:var(--shadow);
    border:1px solid var(--border);
    transition:.3s;
}
.tc-card:hover{ transform:translateY(-6px); box-shadow:0 24px 50px rgba(0,0,0,.12); }

.tc-img-wrap{ position:relative; height:180px; overflow:hidden; }
.tc-img-wrap img{ width:100%; height:100%; object-fit:cover; transition:.4s; }
.tc-card:hover .tc-img-wrap img{ transform:scale(1.05); }
.tc-img-placeholder{
    width:100%; height:180px;
    background:linear-gradient(135deg,var(--brand),var(--brand-2));
    display:flex; align-items:center; justify-content:center;
    color:rgba(255,255,255,.35); font-size:50px;
}

.tc-badge{
    position:absolute; bottom:12px; left:14px;
    background:rgba(18,49,76,.85); backdrop-filter:blur(6px);
    color:var(--green); border-radius:10px; padding:5px 12px;
    font-size:12px; font-weight:700;
}

.tc-body{ padding:20px; }

.tc-title{
    font-size:17px; font-weight:800; margin:0 0 12px;
    line-height:1.3; color:var(--text);
}

.tc-meta{ display:flex; gap:16px; margin-bottom:18px; flex-wrap:wrap; }
.tc-meta-item{ display:flex; align-items:center; gap:7px; font-size:13px; color:var(--muted); }
.tc-meta-item i{ color:var(--green); }

.tc-actions{ display:flex; gap:10px; align-items:center; }
.tc-btn-primary{
    flex:1; background:linear-gradient(135deg,var(--brand),var(--brand-2));
    color:var(--btn-primary-text) !important; border-radius:12px; padding:11px 16px;
    font-weight:700; font-size:14px; text-align:center; transition:.2s;
    display:flex; align-items:center; justify-content:center;
}
.tc-btn-primary:hover{ filter:brightness(1.15); color:var(--btn-primary-text) !important; }
.tc-secondary-actions{ display:flex; gap:8px; }
.tc-btn-secondary{
    width:42px; height:42px; border-radius:12px;
    background:var(--surface-2); border:1px solid var(--border);
    display:flex; align-items:center; justify-content:center;
    color:var(--muted); font-size:16px; transition:.2s;
}
.tc-btn-secondary:hover{ border-color:var(--green); color:var(--green); background:rgba(159,213,178,.08); }

.tc-empty{
    text-align:center; padding:100px 20px; color:var(--muted);
}
.tc-empty-icon{
    width:100px; height:100px; border-radius:50%;
    background:var(--surface-2); border:2px dashed var(--border);
    display:flex; align-items:center; justify-content:center;
    margin:0 auto 24px; font-size:40px; color:var(--border);
}
.tc-empty h4{ font-weight:800; margin-bottom:10px; color:var(--text); }
.tc-empty p{ max-width:400px; margin:0 auto; }

@media(max-width:600px){
    .tc-grid{ grid-template-columns:1fr; }
}
</style>
