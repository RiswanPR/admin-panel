<div class="container-fluid mt-4 mb-5">

    <!-- HERO -->
    <div class="hero-card mb-4">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">

            <div>
                <small class="text-light opacity-75 d-block mb-1">
                    Chapter Classes
                </small>

                <h2 class="text-white fw-bold m-0">
                    Add New Class
                </h2>
            </div>

            <a href="javascript:history.back()" class="btn btn-light px-4 py-2">
                <i class="fa-solid fa-arrow-left me-2"></i>
                Back
            </a>

        </div>
    </div>


    <div class="row justify-content-center">
        <div class="col-xl-11">

            <div class="upload-card">

                <div id="errorMsg" class="alert alert-danger d-none"></div>

                <form id="classForm" action="/add-class" method="POST" enctype="multipart/form-data">

                    <input type="hidden" name="chapterId" value="{{chapterCode}}">
                    <input type="hidden" name="courseType" value="{{courseType}}">

                    <div class="row g-5">

                        <!-- LEFT -->
                        <div class="col-lg-8">

                            <div class="row g-4">

                                <div class="col-12">
                                    <label class="form-label fw-semibold mb-2">
                                        Class Title
                                    </label>

                                    <input type="text" name="title" id="title" class="form-control custom-input"
                                        placeholder="Enter class title..." required>
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label fw-semibold mb-2">
                                        Duration
                                    </label>

                                    <input type="text" name="duration" class="form-control custom-input"
                                        placeholder="e.g. 10:00">
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label fw-semibold mb-2">
                                        Chapter
                                    </label>

                                    <input type="text" class="form-control custom-input"
                                        value="{{chapterCode}}" readonly>
                                </div>

                                <div class="col-12">
                                    <label class="form-label fw-semibold mb-2">
                                        Description
                                    </label>

                                    <textarea name="description" id="description" rows="4"
                                        class="form-control custom-input" placeholder="Enter class description..."
                                        required></textarea>
                                </div>

                            </div>


                            <!-- UPLOADS -->
                            <div class="row g-4 mt-2">

                                <!-- THUMBNAIL -->
                                <div class="col-12">

                                    <label class="form-label fw-semibold mb-3">
                                        Thumbnail *
                                    </label>

                                    <div class="d-flex align-items-center gap-3">
                                        <div id="addClassPreview" style="width:100%; max-width:240px; aspect-ratio:16/9; background:var(--surface-2); border-radius:12px; display:flex; align-items:center; justify-content:center; color:var(--muted); border: 2px dashed var(--border); overflow:hidden;">
                                            <i class="fa-solid fa-image fa-2x"></i>
                                        </div>
                                    </div>
                                    <input type="hidden" name="coverImageUrl" id="addClassCoverUrl">
                                    <button type="button" class="btn btn-outline-primary mt-3" onclick="openCoverSelector('addClassCoverUrl', 'addClassPreview')">
                                        <i class="fa-solid fa-images me-2"></i>Select Cover
                                    </button>

                                </div>

                            </div>

                        </div>


                        <!-- RIGHT -->
                        <div class="col-lg-4">

                            <div class="summary-card sticky-top">

                                <h5 class="fw-bold mb-4">
                                    Class Summary
                                </h5>

                                <div class="summary-box">

                                    <p class="text-muted mb-2">Title</p>
                                    <h5 id="summaryTitle" class="fw-bold mb-4">
                                        -
                                    </h5>

                                    <p class="text-muted mb-2">Thumbnail</p>
                                    <h6 id="thumbStatus" class="mb-4 text-warning">
                                        Waiting...
                                    </h6>

                                    <hr>

                                    <div id="uploadStatus" class="fw-bold text-primary">
                                        Ready to create
                                    </div>

                                </div>

                            </div>

                        </div>

                    </div>


                    <div class="text-center mt-5">
                        <button type="submit" id="submitBtn" class="btn btn-success px-5 py-3">
                            <i class="fa-solid fa-plus me-2"></i>
                            Add Class
                        </button>
                    </div>

                </form>

            </div>

        </div>
    </div>
</div>


<style>
    .hero-card {
        background: linear-gradient(135deg, #12314c, #1d4e89);
        border-radius: 28px;
        padding: 32px;
        box-shadow: 0 18px 40px rgba(18, 49, 76, .22);
    }

    .upload-card {
        background: var(--surface);
        border-radius: 28px;
        padding: 35px;
        box-shadow: 0 12px 35px rgba(0, 0, 0, .08);
        border: 1px solid rgba(159, 213, 178, .12);
    }

    .custom-input {
        min-height: 56px;
        border-radius: 14px;
        padding: 14px 18px;
        background: var(--surface-2);
        color: var(--text);
        border: 1px solid var(--border);
    }

    .custom-input::placeholder {
        color: var(--muted);
        opacity: 1;
    }

    .summary-card {
        background: var(--surface-2);
        border-radius: 24px;
        padding: 28px;
        top: 20px;
        border: 1px solid var(--border);
    }

    .summary-box {
        background: var(--surface);
        border-radius: 18px;
        padding: 22px;
        border: 1px solid rgba(159, 213, 178, .12);
    }

    html[data-theme="dark"] .hero-card {
        box-shadow: 0 18px 40px rgba(0, 0, 0, .45);
    }

    html[data-theme="dark"] .upload-card {
        box-shadow: 0 12px 35px rgba(0, 0, 0, .35);
    }

    html[data-theme="dark"] .summary-card,
    html[data-theme="dark"] .summary-box {
        border-color: rgba(255, 255, 255, .08);
    }
</style>

<script>
    const classForm = document.getElementById("classForm");
    const submitBtn = document.getElementById("submitBtn");
    const errorMsg = document.getElementById("errorMsg");

    const title = document.getElementById("title");
    const summaryTitle = document.getElementById("summaryTitle");
    const thumbStatus = document.getElementById("thumbStatus");

    function showError(msg) {
        errorMsg.classList.remove("d-none");
        errorMsg.innerText = msg;
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function clearError() {
        errorMsg.classList.add("d-none");
        errorMsg.innerText = "";
    }

    // title summary
    if (title && summaryTitle) {
        title.addEventListener("input", () => {
            summaryTitle.innerText = title.value || "-";
        });
    }

    // cover selected callback
    window.onCoverSelected = function (url, targetId) {
        if (targetId === "addClassCoverUrl") {
            if (thumbStatus) {
                thumbStatus.className = "text-success";
                thumbStatus.innerText = "Ready";
            }
        }
    };

    classForm.addEventListener("submit", (e) => {
        const coverUrl = document.getElementById("addClassCoverUrl").value;
        if (!coverUrl) {
            e.preventDefault();
            showError("Please select a class cover image");
            return;
        }

        clearError();
        submitBtn.disabled = true;
        submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Adding...';
    });
</script>

{{> cover-selector-modal}}
