<div class="container-fluid mt-4 mb-5">

    <!-- HERO -->
    <div class="hero-card mb-4">

        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">

            <div>
                <small class="text-light opacity-75 d-block mb-1">
                    Class Resources
                </small>

                <h2 class="text-white fw-bold m-0">
                    Edit Exercise
                </h2>
                <p class="text-light opacity-75 mt-2 mb-0">
                    Update files attached to this class
                </p>

                <span class="hero-badge mt-2">
                    Update Class Attachment
                </span>
            </div>

            <a href="/chapters/exercises/{{chapterId}}/{{classId}}" class="btn btn-light px-4 py-2">
                <i class="fa-solid fa-arrow-left me-2"></i>
                Back
            </a>

        </div>

    </div>


    <div class="row justify-content-center">
        <div class="col-xl-10 col-lg-11">

            <div class="upload-card">

                <div id="errorMsg" class="alert alert-danger d-none"></div>

                <form id="exerciseForm" action="/edit-exercise" method="POST" enctype="multipart/form-data">

                    <!-- IDs -->
                    <input type="hidden" name="exerciseId" value="{{exercise._id}}">

                    <input type="hidden" name="chapterId" value="{{chapterId}}">
                    <input type="hidden" name="classId" value="{{classId}}">

                    <div class="row g-5">

                        <!-- LEFT -->
                        <div class="col-lg-7">

                            <!-- TITLE -->
                            <div class="mb-4">
                                <label class="form-label fw-semibold mb-2">
                                    Exercise Title
                                </label>

                                <input type="text" name="title" id="exerciseTitle" value="{{exercise.title}}"
                                    class="form-control custom-input" required>
                            </div>

                            <!-- CURRENT FILE -->
                            <div class="current-file-card mb-4">

                                <small class="text-muted d-block mb-3">
                                    Current File
                                </small>

                                <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">

                                    <div class="d-flex align-items-center gap-3">

                                        <div class="file-icon-big" id="currentIcon">
                                            <i class="fa-solid fa-file"></i>
                                        </div>

                                        <div>
                                            <h6 class="fw-bold mb-1">
                                                {{exercise.title}}
                                            </h6>
                                            <small class="text-muted">
                                                {{#if exercise.fileUrl}}{{exercise.fileUrl}}{{else}}{{exercise.file}}{{/if}}
                                            </small>

                                            <span class="type-chip" id="currentType">
                                                {{exercise.type}}
                                            </span>
                                        </div>

                                    </div>

                                    <a href="{{#if exercise.fileUrl}}{{exercise.fileUrl}}{{else}}{{exercise.file}}{{/if}}" target="_blank" class="btn btn-primary">
                                        View File
                                    </a>

                                </div>

                            </div>

                            <!-- REPLACE -->
                            <div class="mb-4">
                                <label class="form-label fw-semibold mb-3">
                                    Replace File (optional)
                                </label>

                                <div class="upload-area" onclick="document.getElementById('fileInput').click()">

                                    <div id="uploadPlaceholder" class="upload-placeholder">
                                        <i class="fa-solid fa-cloud-arrow-up"></i>
                                        <h5 class="mb-2">
                                            Upload New File
                                        </h5>

                                        <small>
                                            PDF / XLS / XLSX / DWG / ZIP
                                        </small>
                                    </div>

                                    <div id="filePreview" class="file-preview d-none">

                                        <div id="fileIcon" class="file-icon-big">
                                            <i class="fa-solid fa-file"></i>
                                        </div>

                                        <h5 id="previewFileName" class="fw-bold mt-3 mb-2">
                                            File name
                                        </h5>

                                        <span id="previewType" class="type-chip">
                                            File type
                                        </span>

                                        <p id="previewSize" class="text-muted mt-3 mb-0"></p>

                                    </div>

                                    <input type="file" name="file" id="fileInput" hidden accept=".pdf,.xls,.xlsx,.dwg,.zip" onclick="event.stopPropagation()">

                                </div>
                            </div>

                        </div>


                        <!-- RIGHT -->
                        <div class="col-lg-5">

                            <div class="summary-card sticky-top">

                                <h5 class="fw-bold mb-4">
                                    Update Summary
                                </h5>

                                <div class="summary-box">

                                    <p class="mb-2 text-muted">
                                        Title
                                    </p>

                                    <h5 id="summaryTitle" class="fw-bold mb-4">
                                        {{exercise.title}}
                                    </h5>

                                    <p class="mb-2 text-muted">
                                        File Type
                                    </p>

                                    <div id="summaryType">
                                        {{exercise.type}}
                                    </div>

                                    <hr>

                                    <p class="mb-2 text-muted">
                                        Status
                                    </p>

                                    <div id="uploadStatus" class="text-info fw-bold">
                                        Keeping current file
                                    </div>

                                </div>

                            </div>

                        </div>

                    </div>


                    <!-- BUTTON -->
                    <div class="text-center mt-5">
                        <button type="submit" id="submitBtn" class="btn btn-warning px-5 py-3">
                            <i class="fa-solid fa-floppy-disk me-2"></i>
                            Update Exercise
                        </button>
                    </div>

                </form>

            </div>

    </div>
    <div id="uploadOverlay">
        <div class="loader-card">
            <div class="loader-circle mb-4"></div>
            <h3 class="fw-bold mb-2 text-white">Updating Exercise</h3>
            <p id="loaderStage" class="mb-0 text-white-50">Preparing update...</p>
            <div class="progress-shell">
                <div id="progressFill" class="progress-fill"></div>
            </div>
            <div id="progressText" class="progress-text">0%</div>
            <div class="loader-note">Large exercise files may take a few moments. Please keep this page open.</div>
        </div>
    </div>
</div>


<style>
    .hero-card {
        background: linear-gradient(135deg, var(--brand), var(--brand-2));
        border-radius: 28px;
        padding: 32px;
        box-shadow: 0 18px 40px rgba(18, 49, 76, .22);
    }

    .hero-badge {
        display: inline-block;
        padding: 7px 14px;
        border-radius: 12px;
        background: rgba(255, 255, 255, .16);
        color: var(--surface);
        font-size: 13px;
        font-weight: 600;
    }

    .upload-card {
        background: var(--surface);
        border-radius: 28px;
        padding: 35px;
        box-shadow: 0 12px 35px rgba(0, 0, 0, .06);
    }

    .custom-input {
        border-radius: 14px;
        min-height: 56px;
        padding: 14px 18px;
        border: 1px solid #dee2e6;
    }

    .current-file-card {
        background: var(--surface-2);
        border-radius: 22px;
        padding: 22px;
    }

    .upload-area {
        width: 100%;
        aspect-ratio: 1/1;
        border-radius: 24px;
        border: 2px dashed #cfd8e3;
        background: var(--surface-2);
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        overflow: hidden;
    }

    .upload-placeholder,
    .file-preview {
        width: 100%;
        height: 100%;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        text-align: center;
        padding: 30px;
    }

    .upload-placeholder i {
        font-size: 55px;
        color: var(--brand);
        margin-bottom: 18px;
    }

    .file-icon-big {
        width: 95px;
        height: 95px;
        border-radius: 24px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--surface);
        font-size: 38px;
        background: var(--brand);
    }

    .summary-card {
        background: var(--surface-2);
        border-radius: 24px;
        padding: 28px;
        top: 20px;
    }

    .summary-box {
        background: var(--surface);
        border-radius: 18px;
        padding: 22px;
    }

    .type-chip {
        display: inline-block;
        padding: 8px 14px;
        border-radius: 12px;
        font-size: 13px;
        font-weight: 700;
        text-transform: uppercase;
    }

    .pdf-chip {
        background: var(--chip-red-bg);
        color: var(--chip-red-text);
    }

    .excel-chip {
        background: var(--chip-green-bg);
        color: var(--chip-green-text);
    }

    .cad-chip {
        background: var(--chip-blue-bg);
        color: var(--chip-blue-text);
    }

    .zip-chip {
        background: var(--chip-purple-bg);
        color: var(--chip-purple-text);
    }
#uploadOverlay {
    position: fixed;
    inset: 0;
    background: rgba(8, 18, 32, .82);
    backdrop-filter: blur(8px);
    z-index: 999999;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 20px;
}
.loader-card {
    width: 100%;
    max-width: 520px;
    background: rgba(23, 37, 54, .95);
    border: 1px solid rgba(255, 255, 255, .12);
    border-radius: 28px;
    padding: 40px;
    text-align: center;
    color: white;
    box-shadow: 0 20px 60px rgba(0, 0, 0, .45);
}
.loader-circle {
    width: 80px;
    height: 80px;
    margin: auto;
    border-radius: 50%;
    border: 5px solid rgba(255, 255, 255, .18);
    border-top: 5px solid #6f42c1;
    animation: spin 1s linear infinite;
}
@keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
}
.progress-shell {
    width: 100%;
    height: 12px;
    background: rgba(255, 255, 255, .1);
    border-radius: 30px;
    overflow: hidden;
    margin-top: 25px;
}
.progress-fill {
    width: 0%;
    height: 100%;
    border-radius: 30px;
    background: linear-gradient(90deg, #a855f7, #6f42c1);
    transition: width .35s;
}
.progress-text {
    margin-top: 14px;
    font-size: 15px;
    color: white;
    opacity: .9;
    font-weight: 700;
}
.loader-note {
    margin-top: 18px;
    font-size: 13px;
    color: rgba(255, 255, 255, .6);
}
</style>


<script>
    const fileInput = document.getElementById("fileInput");
    const submitBtn = document.getElementById("submitBtn");
    const errorMsg = document.getElementById("errorMsg");

    function showError(msg) {
        errorMsg.classList.remove("d-none");
        errorMsg.innerText = msg;
    }

    function clearError() {
        errorMsg.classList.add("d-none");
        errorMsg.innerText = "";
    }

    function applyType(type, targetId) {
        let el = document.getElementById(targetId);

        if (!el) return;

        let cls = "type-chip";

        if (type === "PDF") cls += " pdf-chip";
        if (type === "EXCEL") cls += " excel-chip";
        if (type === "AUTOCAD") cls += " cad-chip";
        if (type === "ZIP") cls += " zip-chip";

        el.className = cls;
        el.innerText = type;
    }

    /* Current type */
    (() => {
        const current = "{{exercise.type}}".toLowerCase();

        if (current === "pdf") {
            currentIcon.style.background = "#dc3545";
            currentIcon.innerHTML = '<i class="fa-solid fa-file-pdf"></i>';
            applyType("PDF", "currentType");
            applyType("PDF", "summaryType");
        }

        if (current === "excel") {
            currentIcon.style.background = "#198754";
            currentIcon.innerHTML = '<i class="fa-solid fa-file-excel"></i>';
            applyType("EXCEL", "currentType");
            applyType("EXCEL", "summaryType");
        }

        if (current === "autocad") {
            currentIcon.style.background = "#1976d2";
            currentIcon.innerHTML = '<i class="fa-solid fa-drafting-compass"></i>';
            applyType("AUTOCAD", "currentType");
            applyType("AUTOCAD", "summaryType");
        }

        if (current === "zip") {
            currentIcon.style.background = "#6f42c1";
            currentIcon.innerHTML = '<i class="fa-solid fa-file-zipper"></i>';
            applyType("ZIP", "currentType");
            applyType("ZIP", "summaryType");
        }
    })();

    exerciseTitle.addEventListener("input", function () {
        summaryTitle.innerText = this.value || "Exercise Title";
    });

    fileInput.addEventListener("change", function (e) {

        clearError();

        const file = e.target.files[0];
        if (!file) return;

        const ext = file.name.split(".").pop().toLowerCase();
        const allowed = ["pdf", "xls", "xlsx", "dwg", "zip"];

        if (!allowed.includes(ext)) {
            showError("Only PDF / XLS / XLSX / DWG / ZIP allowed");
            fileInput.value = "";
            return;
        }

        if (file.size > 5 * 1024 * 1024 * 1024) {
            showError("Max file size is 5GB");
            fileInput.value = "";
            return;
        }

        let type = "";
        let icon = "";
        let bg = "";

        if (ext === "pdf") {
            type = "PDF";
            icon = "fa-file-pdf";
            bg = "#dc3545";
        }

        if (ext === "xls" || ext === "xlsx") {
            type = "EXCEL";
            icon = "fa-file-excel";
            bg = "#198754";
        }

        if (ext === "dwg") {
            type = "AUTOCAD";
            icon = "fa-drafting-compass";
            bg = "#1976d2";
        }

        if (ext === "zip") {
            type = "ZIP";
            icon = "fa-file-zipper";
            bg = "#6f42c1";
        }

        uploadPlaceholder.classList.add("d-none");
        filePreview.classList.remove("d-none");

        fileIcon.style.background = bg;
        fileIcon.innerHTML = `<i class="fa-solid ${icon}"></i>`;

        previewFileName.innerText = file.name;
        previewSize.innerText =
            (file.size / (1024 * 1024)).toFixed(2) + " MB";

        applyType(type, "previewType");
        applyType(type, "summaryType");

        uploadStatus.className = "text-success fw-bold";
        uploadStatus.innerText = "New file selected";
    });

function formatBytes(bytes) {
    if (!bytes || bytes === 0) return '0 B';
    const k = 1024;
    const sizes = ['B', 'KB', 'MB', 'GB'];
    const i = Math.floor(Math.log(bytes) / Math.log(k));
    return parseFloat((bytes / Math.pow(k, i)).toFixed(1)) + ' ' + sizes[i];
}

function formatTime(secs) {
    if (!secs || secs < 0 || !isFinite(secs)) return '0s';
    if (secs < 60) return Math.ceil(secs) + 's';
    const mins = Math.floor(secs / 60);
    const rem = Math.ceil(secs % 60);
    return `${mins}m ${rem}s`;
}

const exerciseForm = document.getElementById("exerciseForm");
const uploadOverlay = document.getElementById("uploadOverlay");
const loaderStage = document.getElementById("loaderStage");
const progressFill = document.getElementById("progressFill");
const progressText = document.getElementById("progressText");

exerciseForm.addEventListener("submit", function(e) {
    e.preventDefault();

    clearError();
    submitBtn.disabled = true;
    submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Updating...';
    uploadOverlay.style.display = "flex";
    loaderStage.innerText = "Preparing update...";
    progressFill.style.width = "0%";
    progressText.innerText = "0%";

    const formData = new FormData(exerciseForm);
    const xhr = new XMLHttpRequest();
    let uploadStartTime = Date.now();

    xhr.upload.addEventListener("progress", (ev) => {
        if (!ev.lengthComputable) return;

        const pct = (ev.loaded / ev.total) * 85;
        const elapsed = (Date.now() - uploadStartTime) / 1000;
        const speed = ev.loaded / (elapsed || 0.001);
        const remaining = (ev.total - ev.loaded) / (speed || 1);

        progressFill.style.width = pct.toFixed(1) + "%";
        progressText.innerText = Math.floor(pct) + "%";

        if (pct < 5) {
            loaderStage.innerText = "Starting update...";
        } else if (pct < 40) {
            loaderStage.innerText = `Uploading file — ${formatBytes(ev.loaded)} / ${formatBytes(ev.total)} · ${formatBytes(speed)}/s`;
        } else if (pct < 80) {
            loaderStage.innerText = `Uploading file — ${formatBytes(ev.loaded)} / ${formatBytes(ev.total)} · ~${formatTime(remaining)} left`;
        } else {
            loaderStage.innerText = "Almost done uploading...";
        }
    });

    xhr.upload.addEventListener("load", () => {
        progressFill.style.width = "85%";
        progressText.innerText = "85%";
        loaderStage.innerText = "Upload complete · Server is processing & updating Amazon S3...";

        let serverPct = 85;
        window._serverTimer = setInterval(() => {
            serverPct += Math.random() * 1.5;
            if (serverPct > 95) serverPct = 95;
            progressFill.style.width = serverPct.toFixed(1) + "%";
            progressText.innerText = Math.floor(serverPct) + "%";
        }, 800);
    });

    xhr.addEventListener("load", () => {
        clearInterval(window._serverTimer);

        let data;
        try {
            data = JSON.parse(xhr.responseText);
        } catch {
            data = null;
        }

        if (xhr.status >= 200 && xhr.status < 300 && (data?.success || !data)) {
            progressFill.style.width = "100%";
            progressText.innerText = "100%";
            loaderStage.innerText = "✅ Exercise updated successfully!";
            progressFill.style.background = "linear-gradient(90deg, #34d399, #10b981)";

            setTimeout(() => {
                window.location.href = data?.redirect || window.location.href;
            }, 600);
        } else {
            uploadOverlay.style.display = "none";
            submitBtn.disabled = false;
            submitBtn.innerHTML = '<i class="fa-solid fa-floppy-disk me-2"></i>Update Exercise';
            showError(data?.error || 'Update failed. Please try again.');
        }
    });

    xhr.addEventListener("error", () => {
        clearInterval(window._serverTimer);
        uploadOverlay.style.display = "none";
        submitBtn.disabled = false;
        submitBtn.innerHTML = '<i class="fa-solid fa-floppy-disk me-2"></i>Update Exercise';
        showError("Network error. Please check your connection and try again.");
    });

    xhr.open("POST", exerciseForm.action);
    xhr.setRequestHeader("X-Requested-With", "XMLHttpRequest");
    xhr.send(formData);
});
</script>
