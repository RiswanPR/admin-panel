}

.stat-card.stat-green i {
    background: linear-gradient(135deg, #9fd5b2, #70bf8e);
    -webkit-background-clip: text;
}

.stat-card.stat-red i {
    background: linear-gradient(135deg, var(--red), #dc2626);
    -webkit-background-clip: text;
}

.stat-card.stat-yellow i {
    background: linear-gradient(135deg, var(--yellow), #e1d839);
    -webkit-background-clip: text;
}

.stat-card h2 {
    font-size: 28px;
    font-weight: 850;
    margin: 4px 0;
}

.stat-card small {
    font-size: 12px;
    font-weight: 600;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.toolbar-card {
    background: var(--card);
    padding: 16px 20px;
    border-radius: 18px;
    border: 1px solid var(--border);
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 20px;
    box-shadow: var(--shadow);
