@media(max-width:768px) {
    .hero-card,
    .toolbar-card {
        padding: 20px;
    }
    .toolbar-card {
        flex-direction: column;
        align-items: stretch;
    }
}
</style>


<script>
function updateSerialNumbers(){
    let rows=document.querySelectorAll("#myTable tbody tr");
    let count=1;

    rows.forEach(row=>{
        if(row.style.display!=="none"){
            row.querySelector(".si-no").innerText=count++;
        }
    });
}

function searchStudent(){
    let input=document.getElementById("myInput").value.toUpperCase();

    document.querySelectorAll(".student-card-wrap").forEach(card=>{
        let name=card.dataset.name.toUpperCase();
        card.style.display=name.includes(input)?"":"none";
    });

    document.querySelectorAll("#myTable tbody tr").forEach(row=>{
        let name=row.querySelector(".student-name").innerText.toUpperCase();
        row.style.display=name.includes(input)?"":"none";
    });

    updateSerialNumbers();
}

function showGrid(){
    document.getElementById("gridView").style.display="block";
    document.getElementById("tableView").style.display="none";

    gridBtn.classList.add("active");
    tableBtn.classList.remove("active");
}

function showTable(){
    document.getElementById("gridView").style.display="none";
    document.getElementById("tableView").style.display="block";

    tableBtn.classList.add("active");
    gridBtn.classList.remove("active");
}

function calculatePendingFees(){
    let cells=document.querySelectorAll(".pending");

    cells.forEach(cell=>{
        let fee=Number(cell.dataset.fee)||0;
        let paid=Number(cell.dataset.paid)||0;
        let balance=fee-paid;

        cell.innerText="₹"+balance.toLocaleString('en-IN');

        if(balance<=0){
            cell.style.color="#198754";
            cell.style.background="#dff7e7";
        }
    });
}

function updateDashboard(){
    let rows=document.querySelectorAll("#myTable tbody tr");

    let active=0;
    let blocked=0;
    let total=0;

    rows.forEach(row=>{
        let html=row.innerHTML;

        if(html.includes("Active")) active++;
        if(html.includes("Blocked")) blocked++;

        total += Number(
            row.querySelector(".pending").dataset.paid
        ) || 0;
    });

    document.getElementById("activeCount").innerText=active;
    document.getElementById("blockedCount").innerText=blocked;
    document.getElementById("totalCollected").innerText=
        "₹"+total.toLocaleString('en-IN');
}

function changeStatus(studentId,status){

    Swal.fire({
        title:status ? "Approve access?" : "Block access?",
        icon:"question",
        showCancelButton:true,
        confirmButtonText:"Confirm"
    }).then(result=>{

        if(!result.isConfirmed) return;

        fetch('/change-status/'+studentId+'/'+status, {
            method: 'POST'
        })
        .then(res=>res.json())
        .then(data=>{
            if(data.status){
                location.reload();
            }
        });

    });
}

function verifyAccount(studentId) {
    Swal.fire({
        title: "Verify Account?",
        text: "This will mark the user's account as verified.",
        icon: "question",
        showCancelButton: true,
        confirmButtonText: "Verify"
    }).then(result => {
        if (!result.isConfirmed) return;

        fetch('/verify-account/' + studentId, {
            method: 'POST'
        })
        .then(res => res.json())
        .then(data => {
            if (data.status) {
                Swal.fire("Verified!", "", "success").then(() => {
                    location.reload();
                });
            }
        });
    });
}

function deleteStudent(id){

    Swal.fire({
        title:"Delete student?",
        text:"This action cannot be undone",
        icon:"warning",
        showCancelButton:true,
        confirmButtonColor:"#dc3545",
        confirmButtonText:"Delete"
    }).then(result=>{

        if(!result.isConfirmed) return;

        fetch('/delete-student/'+id,{
            method:'POST'
        })
        .then(res=>res.json())
        .then(data=>{

            if(data.success){

                let row=document.getElementById("row-"+id);
                let card=document.getElementById("card-"+id);

                if(row) row.remove();
                if(card) card.remove();

                updateSerialNumbers();
                updateDashboard();

                Swal.fire("Deleted!","","success");
            }

        });

    });
}

window.onload=function(){
    updateSerialNumbers();
    calculatePendingFees();
    updateDashboard();
};
</script>
