<section class="container-fluid mt-4 mb-5">

    <div class="row justify-content-center">
        <div class="col-xl-9 col-lg-10">

            <div class="card border-0 shadow-lg edit-student-card">

                <!-- HEADER -->
                <div class="card-header student-header border-0">
                    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">

                        <div>
                            <h2 class="m-0 fw-bold text-var(--surface)">
                                Edit Student
                            </h2>
                            <small class="text-light opacity-75">
                                Update learner details
                            </small>
                        </div>

                        <a href="/students" class="btn btn-light">
                            <i class="fa-solid fa-arrow-left me-2"></i>
                            Back
                        </a>

                    </div>
                </div>

                <div class="card-body p-4 p-lg-5">

                    <form action="/edit-student/{{student._id}}" method="POST" enctype="multipart/form-data"
                        id="editStudentForm">

                        <div class="row">

                            <!-- LEFT -->
                            <div class="col-lg-8">

                                <!-- NAME -->
                                <div class="mb-4">
                                    <label class="form-label fw-semibold">
                                        Full Name
                                    </label>

                                    <input type="text" class="form-control custom-input" name="name"
                                        value="{{student.name}}" required>
                                </div>

                                <!-- EMAIL + PHONE -->
                                <div class="row">

                                    <div class="col-md-6">
                                        <div class="mb-4">
                                            <label class="form-label fw-semibold">
                                                Email Address
                                            </label>

                                            <input type="email" class="form-control custom-input" name="email"
                                                value="{{student.email}}" required>
                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        <div class="mb-4">
                                            <label class="form-label fw-semibold">
                                                Phone Number
                                            </label>

                                            <input type="text" class="form-control custom-input" name="Phone_Number"
                                                value="{{student.Phone_Number}}" pattern="[0-9]{10}" maxlength="10"
                                                required>
                                        </div>
                                    </div>

                                </div>

                                <!-- COURSE -->
                                <div class="mb-4">
                                    <label class="form-label fw-semibold">
                                        Course
                                    </label>

                                    <select class="form-control custom-input" name="package" id="courseSelect" multiple
                                        required>
                                        {{#each courses}}
                                        <option value="{{this._id}}" data-fee="{{this.Total_Fees}}" {{includesCourse
                                            this._id ../student.course}}>
                                            {{this.name}}
                                        </option>
                                        {{/each}}
                                    </select>
                                </div>

                                <!-- PAID -->
                                <div class="mb-4">
                                    <label class="form-label fw-semibold">
                                        Amount Paid
                                    </label>

                                    <input type="number" class="form-control custom-input" name="Paid_Amount"
                                        id="paidAmount" value="{{student.Paid_Amount}}" required>
                                </div>

                            </div>


                            <!-- RIGHT -->
                            <div class="col-lg-4">

                                <!-- IMAGE -->
                                <div class="profile-box text-center mb-4">

                                    <img id="preview" src="/student-images/{{student._id}}.jpg" class="student-preview"
                                        onerror="this.onerror=null;this.src='/student-images/default-image.jpg';">

                                    <label class="upload-btn mt-3">
                                        <i class="fa-solid fa-camera me-2"></i>
                                        Change Photo
                                        <input type="file" name="image" hidden accept="image/*"
                                            onchange="previewImage(event)">
                                    </label>

                                </div>

                                <!-- SUMMARY -->
                                <div class="summary-card">
                                    <h6 class="fw-bold mb-3">
                                        Fee Summary
                                    </h6>

                                    <p class="mb-2">
                                        Course Fee:
                                        <strong id="courseFee">₹0</strong>
                                    </p>

                                    <p class="mb-2">
                                        Paid:
                                        <strong id="paidPreview">₹0</strong>
                                    </p>

                                    <p class="mb-0">
                                        Balance:
                                        <strong id="balancePreview" class="text-danger">
                                            ₹0
                                        </strong>
                                    </p>
                                </div>

                            </div>

                        </div>


                        <!-- DATES -->
                        <div class="row mt-2">

                            <div class="col-md-4">
                                <label class="form-label fw-semibold">
                                    Start Date
                                </label>

                                <input id="startDate" class="form-control custom-input" type="date" name="Start_Date"
                                    value="{{formatDate student.Start_Date}}" required>
                            </div>

                            <div class="col-md-4">
                                <label class="form-label fw-semibold">
                                    End Date
                                </label>

                                <input id="endDate" class="form-control custom-input" type="date" name="End_Date"
                                    value="{{formatDate student.End_Date}}" required>
                            </div>

                            <div class="col-md-4">
                                <label class="form-label fw-semibold">
                                    Duration
                                </label>

                                <input type="text" class="form-control custom-input bg-light" id="duration"
                                    name="Duration" value="{{student.Duration}}" readonly>
                            </div>

                        </div>


                        <!-- BUTTON -->
                        <div class="text-center mt-5">
                            <button type="submit" class="btn btn-success px-5 py-2">
                                <i class="fa-solid fa-floppy-disk me-2"></i>
                                Update Student
                            </button>
                        </div>

                    </form>

                </div>
            </div>

        </div>
    </div>

</section>


<style>
    .edit-student-card {
        border-radius: 24px;
        overflow: hidden;
    }

    .student-header {
        background: linear-gradient(135deg, var(--brand), var(--brand-2));
        padding: 28px 32px;
    }

    .student-header h2 {
        color: white !important;
    }

    .custom-input {
        border-radius: 12px;
        min-height: 50px;
        border: 1px solid var(--border);
        background: var(--surface);
        color: var(--text);
        padding: 12px 16px;
        transition: all 0.25s ease;
    }

    .custom-input:focus {
        border-color: var(--brand);
        background: var(--card-solid);
        box-shadow: 0 0 0 4px var(--shadow-brand) !important;
    }

    .profile-box,
    .summary-card {
        background: var(--surface-2);
        border: 1px solid var(--border);
        padding: 24px;
        border-radius: 20px;
    }

    .student-preview {
        width: 130px;
        height: 130px;
        border-radius: 50%;
        object-fit: cover;
        border: 4px solid var(--surface);
        box-shadow: var(--shadow);
    }

    .upload-btn {
        display: inline-block;
        padding: 10px 20px;
        border-radius: 12px;
        background: linear-gradient(135deg, var(--brand), var(--brand-2));
        color: var(--btn-primary-text) !important;
        cursor: pointer;
        font-weight: 600;
        transition: all 0.2s ease;
        box-shadow: 0 4px 12px var(--shadow-brand);
    }

    .upload-btn:hover {
        transform: translateY(-1px);
        box-shadow: 0 6px 16px rgba(79, 70, 229, 0.3);
    }

    @media(max-width:768px) {
        .student-header {
            padding: 22px;
        }
    }
</style>


<script>
    const startDate = document.getElementById("startDate");
    const endDate = document.getElementById("endDate");
    const duration = document.getElementById("duration");
    const courseSelect = document.getElementById("courseSelect");
    const paidAmount = document.getElementById("paidAmount");

    function previewImage(e) {
        const file = e.target.files[0];

        if (file) {
            document.getElementById("preview").src =
                URL.createObjectURL(file);
        }
    }

    function calculateDuration() {

        if (startDate.value && endDate.value) {

            const start = new Date(startDate.value);
            const end = new Date(endDate.value);

            const diff = end - start;

            const days =
                Math.floor(diff / (1000 * 60 * 60 * 24)) + 1;

            duration.value =
                days > 0 ? days + " days" : "";
        }
    }

    function updateFeePreview() {

        let fee = 0;
        for (let i = 0; i < courseSelect.options.length; i++) {
            const option = courseSelect.options[i];
            if (option.selected && option.value) {
                fee += Number(option.dataset.fee || 0);
            }
        }

        let paid = Number(paidAmount.value || 0);
        if (paid > fee) {
            paid = fee;
            paidAmount.value = fee;
        }
        if (paid < 0) {
            paid = 0;
            paidAmount.value = 0;
        }

        const balance = fee - paid;

        document.getElementById("courseFee").innerText =
            "₹" + fee.toLocaleString('en-IN');

        document.getElementById("paidPreview").innerText =
            "₹" + paid.toLocaleString('en-IN');

        document.getElementById("balancePreview").innerText =
            "₹" + balance.toLocaleString('en-IN');
    }

    startDate.addEventListener("change", function () {
        endDate.min = this.value;

        if (endDate.value < this.value) {
            endDate.value = "";
        }

        calculateDuration();
    });

    endDate.addEventListener("change", calculateDuration);
    courseSelect.addEventListener("change", updateFeePreview);
    paidAmount.addEventListener("input", updateFeePreview);
    paidAmount.addEventListener("keyup", updateFeePreview);
    paidAmount.addEventListener("change", updateFeePreview);

    document.getElementById("editStudentForm").addEventListener("submit", function (e) {
        let fee = 0;
        for (let i = 0; i < courseSelect.options.length; i++) {
            const option = courseSelect.options[i];
            if (option.selected && option.value) {
                fee += Number(option.dataset.fee || 0);
            }
        }
        let paid = Number(paidAmount.value || 0);
        if (paid > fee) {
            paidAmount.value = fee;
        }
        if (paid < 0) {
            paidAmount.value = 0;
        }
    });

    window.onload = function () {
        calculateDuration();
        updateFeePreview();
    };
</script>