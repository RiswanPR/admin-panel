<div class="container-fluid">

    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <div>
            <h3 class="mb-0 fw-800">Cover Images</h3>
            <p class="text-muted mb-0">Manage reusable cover images for Modules, Chapters, and Classes.</p>
        </div>
        <button class="btn btn-add" data-toggle="modal" data-target="#addCoverModal">
            <i class="fa-solid fa-cloud-arrow-up me-2"></i>Upload Cover
        </button>
    </div>

    <!-- Filters -->
    <div class="card filter-card mb-4">
        <form method="GET" action="/cover-images" class="d-flex gap-3 flex-wrap">
            <div class="flex-grow-1" style="min-width: 200px;">
                <div class="search-box">
                    <i class="fa-solid fa-magnifying-glass"></i>
                    <input type="text" name="search" value="{{query.search}}" class="form-control" placeholder="Search by name...">
                </div>
            </div>
            <div style="width: 200px;">
                <select name="category" class="form-select" onchange="this.form.submit()">
                    <option value="All" {{#ifEquals query.category 'All'}}selected{{/ifEquals}}>All Categories</option>
                    <option value="Module" {{#ifEquals query.category 'Module'}}selected{{/ifEquals}}>Module</option>
                    <option value="Chapter" {{#ifEquals query.category 'Chapter'}}selected{{/ifEquals}}>Chapter</option>
                    <option value="Class" {{#ifEquals query.category 'Class'}}selected{{/ifEquals}}>Class</option>
                    <option value="Day" {{#ifEquals query.category 'Day'}}selected{{/ifEquals}}>Day</option>
                    <option value="General" {{#ifEquals query.category 'General'}}selected{{/ifEquals}}>General</option>
                </select>
            </div>
            <div style="width: 160px;">
                <select name="status" class="form-select" onchange="this.form.submit()">
                    <option value="" {{#unless query.status}}selected{{/unless}}>All Statuses</option>
                    <option value="true" {{#ifEquals query.status 'true'}}selected{{/ifEquals}}>Active</option>
                    <option value="false" {{#ifEquals query.status 'false'}}selected{{/ifEquals}}>Disabled</option>
                </select>
            </div>
            {{#if query.search}}
            <a href="/cover-images" class="btn btn-outline-secondary d-flex align-items-center">Clear</a>
            {{/if}}
            <button type="submit" class="btn btn-secondary d-none">Filter</button>
        </form>
    </div>

    <!-- Grid -->
    <div class="row g-4">
        {{#each images}}
        <div class="col-sm-6 col-md-4 col-lg-3">
            <div class="card cover-card h-100 {{#unless this.status}}disabled-card{{/unless}}">
                <div class="cover-image-wrapper">
                    <img src="{{this.image}}" alt="{{this.title}}" loading="lazy">
                    <div class="cover-actions">
                        <button class="btn btn-sm btn-light" onclick="openEditModal('{{this._id}}', '{{this.title}}', '{{this.category}}', '{{this.status}}')" title="Edit"><i class="fa-solid fa-pen"></i></button>
                        <button class="btn btn-sm btn-danger" onclick="deleteCover('{{this._id}}')" title="Delete"><i class="fa-solid fa-trash"></i></button>
                    </div>
                    {{#unless this.status}}
                    <div class="disabled-overlay">DISABLED</div>
                    {{/unless}}
                </div>
                <div class="card-body p-3">
                    <h6 class="mb-1 text-truncate" title="{{this.title}}">{{this.title}}</h6>
                    <div class="d-flex justify-content-between align-items-center mt-2">
                        <span class="badge category-badge">{{this.category}}</span>
                        <small class="text-muted" style="font-size:11px;">{{formatDate this.createdAt "MMM D, YYYY"}}</small>
                    </div>
                </div>
            </div>
        </div>
        {{else}}
        <div class="col-12 text-center py-5">
            <div class="empty-state">
                <i class="fa-solid fa-images fa-3x text-muted mb-3"></i>
                <h5>No Cover Images Found</h5>
                <p class="text-muted">Upload some cover images to build your media library.</p>
                <button class="btn btn-add mt-2" data-toggle="modal" data-target="#addCoverModal">Upload Now</button>
            </div>
        </div>
        {{/each}}
    </div>
</div>

<!-- ADD MODAL -->
<div class="modal fade" id="addCoverModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-800">Upload Cover Image</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <form id="addCoverForm">
                    <div class="mb-3 upload-area" id="uploadArea" onclick="document.getElementById('coverImageInput').click()">
                        <i class="fa-solid fa-cloud-arrow-up fa-3x mb-2 text-muted"></i>
                        <p class="mb-0 fw-600">Click to upload image</p>
                        <small class="text-muted">Recommended: 1920x1080 (JPG, PNG, WEBP)</small>
                        <input type="file" name="image" id="coverImageInput" class="d-none" accept="image/*" required onchange="previewImage(this, 'previewContainer', 'uploadContent')" onclick="event.stopPropagation()">
                        <div id="previewContainer" class="d-none mt-3" style="width:100%;height:150px;border-radius:12px;overflow:hidden">
                            <img id="imagePreview" src="" style="width:100%;height:100%;object-fit:cover">
                        </div>
                        <div id="uploadContent"></div>
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label fw-bold">Image Title</label>
                        <input type="text" name="title" class="form-control" placeholder="e.g. Module 01 Cover" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Category</label>
                        <select name="category" class="form-select" required>
                            <option value="Module">Module</option>
                            <option value="Chapter">Chapter</option>
                            <option value="Class">Class</option>
                            <option value="Day">Day</option>
                            <option value="General" selected>General</option>
                        </select>
                    </div>
                    <div class="d-flex justify-content-end gap-2 mt-4">
                        <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-add" id="uploadBtn">
                            <span class="spinner-border spinner-border-sm d-none" id="uploadSpinner"></span>
                            <span id="uploadText">Upload Image</span>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- EDIT MODAL -->
<div class="modal fade" id="editCoverModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-800">Edit Cover Image</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <form id="editCoverForm">
                    <input type="hidden" name="id" id="editId">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Image Title</label>
                        <input type="text" name="title" id="editTitle" class="form-control" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Category</label>
                        <select name="category" id="editCategory" class="form-select" required>
                            <option value="Module">Module</option>
                            <option value="Chapter">Chapter</option>
                            <option value="Class">Class</option>
                            <option value="Day">Day</option>
                            <option value="General">General</option>
                        </select>
                    </div>
                    <div class="mb-3 form-check form-switch">
                        <input class="form-check-input" type="checkbox" name="status" id="editStatus" value="true">
                        <label class="form-check-label fw-bold" for="editStatus">Active Status</label>
                        <small class="d-block text-muted">If disabled, teachers cannot select this image.</small>
                    </div>
                    <div class="d-flex justify-content-end gap-2 mt-4">
                        <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-add">Save Changes</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
.btn-add{
    background:linear-gradient(135deg,#9FD5B2,#6dbf96);
    color:#082032; font-weight:700; border:none; border-radius:12px;
    padding:10px 22px; transition:.2s;
}
.btn-add:hover{ transform:translateY(-2px); filter:brightness(.95); color:#082032; }

.filter-card{
    border-radius: 16px;
    padding: 16px;
    background: var(--surface);
    border: 1px solid var(--border);
}
.search-box{ position:relative; }
.search-box i{ position:absolute; left:14px; top:50%; transform:translateY(-50%); color:var(--muted); }
.search-box input{ padding-left:40px; border-radius:10px; background:var(--surface-2); border-color:var(--border); color:var(--text); }

.cover-card{
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid var(--border);
    background: var(--surface);
    transition: transform .2s, box-shadow .2s;
}
.cover-card:hover{
    transform: translateY(-4px);
    box-shadow: 0 10px 25px rgba(0,0,0,.08);
}
.cover-image-wrapper{
    position: relative;
    width: 100%;
    padding-top: 56.25%; /* 16:9 Aspect Ratio */
    background: var(--surface-2);
}
.cover-image-wrapper img{
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
    object-fit: cover;
}
.cover-actions{
    position: absolute;
    top: 10px; right: 10px;
    display: flex; gap: 8px;
    opacity: 0;
    transition: opacity .2s;
}
.cover-card:hover .cover-actions{ opacity: 1; }
.category-badge{
    background: rgba(18,49,76,.1);
    color: #12314C;
    padding: 6px 10px;
    border-radius: 8px;
    font-weight: 700;
}
html[data-theme="dark"] .category-badge{ background:rgba(159,213,178,.15); color:#9FD5B2; }

.disabled-card{ opacity: 0.6; filter: grayscale(80%); }
.disabled-overlay{
    position: absolute; top: 0; left: 0; width: 100%; height: 100%;
    background: rgba(0,0,0,.5); color: #fff; font-weight: 800;
    display: flex; align-items: center; justify-content: center;
    letter-spacing: 2px;
}

.upload-area{
    border: 2px dashed var(--border);
    border-radius: 16px;
    padding: 30px;
    text-align: center;
    cursor: pointer;
    background: var(--surface-2);
    transition: .2s;
}
.upload-area:hover{ border-color: #9FD5B2; background: rgba(159,213,178,.05); }

</style>

<script>
function previewImage(input, containerId, contentId) {
    const container = document.getElementById(containerId);
    const content = document.getElementById(contentId);
    const img = document.getElementById('imagePreview');
    
    if (input.files && input.files[0]) {
        const reader = new FileReader();
        reader.onload = function(e) {
            img.src = e.target.result;
            container.classList.remove('d-none');
        }
        reader.readAsDataURL(input.files[0]);
    }
}

document.getElementById('addCoverForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    const btn = document.getElementById('uploadBtn');
    const spinner = document.getElementById('uploadSpinner');
    const text = document.getElementById('uploadText');
    
    btn.disabled = true;
    spinner.classList.remove('d-none');
    text.innerText = 'Uploading...';
    
    const formData = new FormData(this);
    
    try {
        const res = await fetch('/cover-images', { method: 'POST', body: formData });
        const data = await res.json();
        
        if (data.success) {
            Swal.fire({ icon:'success', title:'Uploaded!', timer:1200, showConfirmButton:false });
            setTimeout(() => location.reload(), 1200);
        } else {
            Swal.fire('Error', data.message || 'Upload failed', 'error');
            btn.disabled = false;
            spinner.classList.add('d-none');
            text.innerText = 'Upload Image';
        }
    } catch(err) {
        Swal.fire('Error', 'Network error', 'error');
        btn.disabled = false;
        spinner.classList.add('d-none');
        text.innerText = 'Upload Image';
    }
});

function openEditModal(id, title, category, status) {
    document.getElementById('editId').value = id;
    document.getElementById('editTitle').value = title;
    document.getElementById('editCategory').value = category;
    document.getElementById('editStatus').checked = status === 'true';
    $('#editCoverModal').modal('show');
}

document.getElementById('editCoverForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    const id = document.getElementById('editId').value;
    const formData = new FormData(this);
    
    // Status is checkbox, if not checked it won't be in formData
    if(!document.getElementById('editStatus').checked) {
        formData.append('status', 'false');
    }
    
    try {
        const res = await fetch(`/cover-images/${id}/edit`, { method: 'POST', body: formData });
        const data = await res.json();
        if(data.success) {
            location.reload();
        } else {
            Swal.fire('Error', data.message, 'error');
        }
    } catch(err) {
        Swal.fire('Error', 'Network error', 'error');
    }
});

function deleteCover(id) {
    Swal.fire({
        title: 'Delete this cover image?',
        text: "This action cannot be undone.",
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#d33',
        cancelButtonColor: '#6c757d',
        confirmButtonText: 'Yes, delete it!'
    }).then(async (result) => {
        if (result.isConfirmed) {
            try {
                const res = await fetch(`/cover-images/${id}`, { method: 'DELETE' });
                const data = await res.json();
                if(data.success) {
                    location.reload();
                } else {
                    Swal.fire('Error', data.message, 'error');
                }
            } catch(err) {
                Swal.fire('Error', 'Network error', 'error');
            }
        }
    });
}
</script>
