<div class="container-fluid mt-4 mb-5">

    <!-- HERO -->
    <div class="hero-card mb-4" style="background: linear-gradient(135deg, var(--brand) 0%, var(--brand-2) 100%); border-radius: 24px; padding: 32px; box-shadow: var(--shadow);">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">

            <div>
                <small class="text-light opacity-75 d-block mb-1 fw-600" style="letter-spacing: 0.5px;">
                    Administrative Overview
                </small>
                <h2 class="text-white fw-bold m-0" style="font-size: 26px;">
                    All Classes Catalog
                </h2>
                <span class="hero-badge mt-2">
                    Multi-Source Video Learning
                </span>
            </div>

            <div class="d-flex align-items-center gap-2">
                <span class="badge bg-light text-dark px-3 py-2 fw-bold" style="border-radius: 10px; font-size: 13px;">
                    {{classes.length}} Total Classes
                </span>
            </div>

        </div>
    </div>


    <!-- DASHBOARD STATS -->
    <div class="row g-4 mb-4">

        <div class="col-lg-3 col-md-6">
            <div class="stat-card-premium stat-total">
                <div class="stat-info">
                    <small>Total Classes</small>
                    <h2>{{classes.length}}</h2>
                </div>
                <div class="stat-icon-wrap">
                    <i class="fa-solid fa-video"></i>
                </div>
            </div>
        </div>

        <div class="col-lg-3 col-md-6">
            <div class="stat-card-premium stat-duration">
                <div class="stat-info">
                    <small>Total Duration</small>
                    <h2 id="totalDuration">0 min</h2>
                </div>
                <div class="stat-icon-wrap">
                    <i class="fa-solid fa-clock"></i>
                </div>
            </div>
        </div>

        <div class="col-lg-3 col-md-6">
            <div class="stat-card-premium stat-s3">
                <div class="stat-info">
                    <small>Amazon S3 Cloud</small>
                    <h2 id="s3Count">0</h2>
                </div>
                <div class="stat-icon-wrap">
                    <i class="fa-brands fa-aws"></i>
                </div>
            </div>
        </div>

        <div class="col-lg-3 col-md-6">
            <div class="stat-card-premium stat-vdo">
                <div class="stat-info">
                    <small>VdoCipher Sec</small>
                    <h2 id="vdoCount">0</h2>
                </div>
                <div class="stat-icon-wrap">
                    <i class="fa-solid fa-shield-halved"></i>
                </div>
            </div>
        </div>

    </div>


    <!-- SEARCH + VIEW TOGGLE -->
    <div class="toolbar-card mb-4" style="background: var(--surface); border: 1px solid var(--border); border-radius: 18px; padding: 16px; box-shadow: var(--shadow);">
        <div class="search-box">
            <i class="fa-solid fa-magnifying-glass"></i>
            <input type="text" id="myInput" placeholder="Search class title, course, or chapter..." onkeyup="searchClass()">
        </div>

        <div class="view-toggle">
            <button id="gridBtn" class="active" onclick="showGrid()">
                <i class="fa-solid fa-table-cells-large"></i>
            </button>
            <button id="tableBtn" onclick="showTable()">
                <i class="fa-solid fa-table-list"></i>
            </button>
        </div>
    </div>


    <!-- GRID VIEW -->
    <div id="gridView">
        <div class="row g-4">

            {{#if classes.length}}
            {{#each classes}}
            <div class="col-xl-3 col-lg-4 col-md-6 class-card-wrap" data-name="{{this.title}} {{this.courseName}} {{this.chapterTitle}}" data-duration="{{this.duration}}" data-source="{{this.videoSource}}">
                <div class="class-card">

                    <!-- THUMBNAIL -->
                    <div class="class-thumb-wrap">
                        {{#if this.thumbnail}}
                        <img src="{{resolveImage this.thumbnail 'class-images'}}" alt="{{this.title}}" class="class-thumb">
                        {{else}}
                        <div class="class-thumb-placeholder">
                            <i class="fa-solid fa-play"></i>
                        </div>
                        {{/if}}

                        <div class="thumb-overlay">
                            {{#if (eq this.videoSource 's3')}}
                            <span class="video-badge s3-badge">
                                <i class="fa-brands fa-aws me-1"></i>S3 Cloud
                            </span>
                            {{else}}
                            <span class="video-badge vdo-badge">
                                <i class="fa-solid fa-shield-halved me-1"></i>VdoCipher
                            </span>
                            {{/if}}
                        </div>
                    </div>

                    <!-- BODY -->
                    <div class="class-body">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <span class="order-badge">#{{this.order}}</span>
                            <span class="duration-chip" data-duration="{{this.duration}}">{{formatDuration this.duration}}</span>
                        </div>

                        <h6 class="class-title fw-bold text-truncate-2" title="{{this.title}}">
                            {{this.title}}
                        </h6>

                        <div class="class-context mb-3">
                            <span class="course-badge text-truncate d-block" title="Course: {{this.courseName}}">
                                <i class="fa-solid fa-graduation-cap me-1"></i>{{this.courseName}}
                            </span>
                            <span class="chapter-badge text-truncate d-block mt-1" title="Chapter: {{this.chapterTitle}}">
                                <i class="fa-solid fa-book me-1"></i>{{this.chapterTitle}}
                            </span>
                        </div>

                        <div class="mt-auto">
                            <!-- Exercises -->
                            <a href="/chapters/exercises/{{this.chapterCode}}/{{this._id}}" class="btn btn-dark btn-sm w-100 mb-2">
                                <i class="fa-solid fa-file-lines me-2"></i>Exercises
                                <span class="badge bg-light text-dark ms-2">{{this.exercisesCount}}</span>
                            </a>

                            <!-- Watch Class -->
                            {{#if (eq this.videoSource 's3')}}
                            <button class="btn btn-info btn-sm w-100 mb-2" onclick="watchS3Class('{{this.chapterCode}}','{{this._id}}')">
                                <i class="fa-solid fa-eye me-1"></i>Watch
                            </button>
                            {{else}}
                            <button class="btn btn-info btn-sm w-100 mb-2" onclick="watchVdoClass('{{this.chapterCode}}','{{this._id}}')">
                                <i class="fa-solid fa-eye me-1"></i>Watch
                            </button>
                            {{/if}}

                            <!-- Preview -->
                            {{#if (eq this.videoSource 's3')}}
                            <button class="btn btn-success btn-sm w-100 mb-2" onclick="previewS3Video('{{this.videoUrl}}')">
                                <i class="fa-solid fa-play me-1"></i>Preview
                            </button>
                            {{else}}
                            <button class="btn btn-success btn-sm w-100 mb-2" onclick="previewVideo('{{this.videoId}}')">
                                <i class="fa-solid fa-play me-1"></i>Preview
                            </button>
                            {{/if}}

                            <!-- Actions -->
                            <div class="d-flex gap-2">
                                <a href="/edit-class/{{this.chapterCode}}/{{this._id}}" class="btn btn-outline-secondary btn-sm w-100">
                                    Edit
                                </a>
                                <button class="btn btn-outline-danger btn-sm w-100" onclick="deleteClass('{{this.chapterCode}}','{{this._id}}')">
                                    Delete
                                </button>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
            {{/each}}
            {{/if}}

        </div>
    </div>


    <!-- TABLE VIEW -->
    <div id="tableView" style="display:none;">
        <div class="table-responsive">
            <table class="table premium-table align-middle" id="myTable">
                <thead>
                    <tr>
                        <th style="width: 60px;">#</th>
                        <th>Class Title</th>
                        <th>Course</th>
                        <th>Chapter</th>
                        <th>Source</th>
                        <th>Duration</th>
                        <th style="width: 200px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {{#if classes.length}}
                    {{#each classes}}
                    <tr>
                        <td class="si-no"></td>
                        <td class="class-name fw-bold">{{this.title}}</td>
                        <td><span class="badge bg-light text-dark">{{this.courseName}}</span></td>
                        <td><span class="badge bg-light text-dark">{{this.chapterTitle}}</span></td>
                        <td>
                            {{#if (eq this.videoSource 's3')}}
                            <span class="video-badge s3-badge"><i class="fa-brands fa-aws me-1"></i>S3</span>
                            {{else}}
                            <span class="video-badge vdo-badge"><i class="fa-solid fa-shield-halved me-1"></i>VdoCipher</span>
                            {{/if}}
                        </td>
                        <td><span class="duration-chip" data-duration="{{this.duration}}">{{formatDuration this.duration}}</span></td>
                        <td>
                            <div class="d-flex gap-2">
                                <a href="/watch-class/{{this.chapterCode}}/{{this._id}}" class="btn btn-info btn-sm" title="Watch Class">
                                    <i class="fa-solid fa-eye"></i>
                                </a>
                                {{#if (eq this.videoSource 's3')}}
                                <button class="btn btn-success btn-sm" onclick="previewS3Video('{{this.videoUrl}}')">
                                    <i class="fa-solid fa-play"></i>
                                </button>
                                {{else}}
                                <button class="btn btn-success btn-sm" onclick="previewVideo('{{this.videoId}}')">
                                    <i class="fa-solid fa-play"></i>
                                </button>
                                {{/if}}
                                <a href="/edit-class/{{this.chapterCode}}/{{this._id}}" class="btn btn-outline-secondary btn-sm">
                                    <i class="fa-solid fa-pen"></i>
                                </a>
                                <button class="btn btn-outline-danger btn-sm" onclick="deleteClass('{{this.chapterCode}}','{{this._id}}')">
                                    <i class="fa-solid fa-trash"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                    {{/each}}
                    {{/if}}
                </tbody>
            </table>
        </div>
    </div>


    <!-- EMPTY STATE -->
    {{#unless classes.length}}
    <div class="empty-box text-center">
        <div class="empty-icon-wrap mb-4">
            <i class="fa-solid fa-video"></i>
        </div>
        <h4 class="fw-800 mb-2">No Classes Found</h4>
        <p class="text-muted mb-4" style="max-width: 400px; margin: 0 auto;">There are no classes created in any chapters or courses yet.</p>
        <a href="/chapters" class="btn btn-success px-4 py-2">
            <i class="fa-solid fa-book-open me-2"></i>Go to Chapters
        </a>
    </div>
    {{/unless}}

</div>


<!-- VIDEO MODAL PREVIEW -->
<div id="videoModal" class="video-modal">
    <div class="video-box">
        <button class="close-video" onclick="closeVideo()">
            ×
        </button>
        <iframe id="videoFrame" allowfullscreen allow="encrypted-media; autoplay; fullscreen; picture-in-picture" referrerpolicy="no-referrer" sandbox="allow-scripts allow-same-origin allow-forms allow-popups allow-presentation"></iframe>
        <video id="s3VideoPlayer" controls playsinline disablepictureinpicture controlsList="nodownload nofullscreen noremoteplayback" style="width:100%;height:100%;display:none;"></video>
    </div>
</div>


<style>
/* Stats Layout */
.stat-card-premium {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 22px;
    padding: 24px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    box-shadow: var(--shadow);
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}
.stat-card-premium:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow), var(--shadow-glow);
}
.stat-card-premium .stat-info small {
    display: block;
    color: var(--muted);
    font-size: 13px;
    font-weight: 600;
    margin-bottom: 4px;
}
.stat-card-premium .stat-info h2 {
    font-size: 32px;
    font-weight: 800;
    margin: 0;
    color: var(--text);
}
.stat-card-premium .stat-icon-wrap {
    width: 56px;
    height: 56px;
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 24px;
}
.stat-total .stat-icon-wrap { background: rgba(18, 49, 76, 0.08); color: var(--text); }
html[data-theme="dark"] .stat-total .stat-icon-wrap { background: rgba(159, 213, 178, 0.12); color: var(--green); }

.stat-duration .stat-icon-wrap { background: rgba(25, 135, 84, 0.1); color: #198754; }
.stat-s3 .stat-icon-wrap { background: rgba(255, 153, 0, 0.12); color: #ff9900; }
.stat-vdo .stat-icon-wrap { background: rgba(18, 49, 76, 0.1); color: var(--brand); }
html[data-theme="dark"] .stat-vdo .stat-icon-wrap { background: rgba(159, 213, 178, 0.1); color: var(--green); }

/* Class Card */
.class-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 22px;
    overflow: hidden;
    box-shadow: var(--shadow);
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
    height: 100%;
    display: flex;
    flex-direction: column;
}
.class-card:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow), var(--shadow-glow);
    border-color: rgba(159, 213, 178, 0.3);
}

.class-thumb-wrap {
    position: relative;
    aspect-ratio: 16/9;
    background: var(--surface-2);
    overflow: hidden;
}
.class-thumb {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
}
.class-card:hover .class-thumb {
    transform: scale(1.04);
}
.class-thumb-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--muted);
    font-size: 32px;
}
.thumb-overlay {
    position: absolute;
    top: 10px;
    right: 10px;
}

.video-badge {
    display: inline-flex;
    align-items: center;
    padding: 4px 10px;
    border-radius: 6px;
    font-size: 11px;
    font-weight: 700;
    color: white;
}
.s3-badge { background: #ff9900; }
.vdo-badge { background: var(--brand); }

.class-body {
    padding: 20px;
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
}
.class-title {
    font-size: 15px;
    color: var(--text);
    line-height: 1.4;
    min-height: 42px;
}
.class-context {
    border-top: 1px solid var(--border);
    padding-top: 12px;
}
.course-badge, .chapter-badge {
    font-size: 12px;
    color: var(--muted);
}

.order-badge {
    font-size: 11px;
    font-weight: 800;
    padding: 3px 8px;
    background: rgba(18, 49, 76, 0.08);
    color: var(--text);
    border-radius: 6px;
}
html[data-theme="dark"] .order-badge { background: rgba(159, 213, 178, 0.12); color: var(--green); }

.duration-chip {
    font-size: 11px;
    font-weight: 700;
    color: var(--muted);
}

.btn-outline-secondary {
    border: 1px solid var(--border) !important;
    background: var(--surface-2) !important;
    color: var(--muted) !important;
    border-radius: 12px;
}
.btn-outline-secondary:hover {
    background: var(--surface) !important;
    color: var(--text) !important;
    border-color: var(--text) !important;
}

.btn-outline-danger {
    border: 1px solid rgba(239, 68, 68, 0.2) !important;
    background: rgba(239, 68, 68, 0.04) !important;
    color: var(--red) !important;
    border-radius: 12px;
}
.btn-outline-danger:hover {
    background: var(--red) !important;
    color: white !important;
    border-color: transparent !important;
}

/* Empty State */
.empty-box {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 24px;
    padding: 80px 40px;
    box-shadow: var(--shadow);
}
.empty-icon-wrap {
    width: 90px;
    height: 90px;
    border-radius: 50%;
    background: rgba(159, 213, 178, 0.12);
    color: var(--green);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 38px;
    margin: 0 auto;
}

/* Video Modal Styling */
.video-modal {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: rgba(8, 16, 26, 0.75);
    backdrop-filter: blur(10px);
    align-items: center;
    justify-content: center;
}
.video-box {
    width: min(900px, 94%);
    aspect-ratio: 16/9;
    position: relative;
    border-radius: 20px;
    overflow: hidden;
    background: black;
    box-shadow: 0 24px 60px rgba(0,0,0,0.3);
}
.close-video {
    position: absolute;
    top: 15px;
    right: 15px;
    background: rgba(255,255,255,0.2);
    color: white;
    border: none;
    font-size: 24px;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 20;
    transition: background 0.2s;
}
.close-video:hover {
    background: rgba(255,255,255,0.35);
}
#videoFrame {
    width: 100%;
    height: 100%;
    border: none;
}
</style>


<script>
    function formatDuration(seconds) {
        seconds = Number(seconds) || 0;
        const hours = Math.floor(seconds / 3600);
        const minutes = Math.floor((seconds % 3600) / 60);
        const remainingSeconds = seconds % 60;

        if (hours > 0) return `${hours}h ${minutes}m`;
        if (minutes > 0) return `${minutes}m ${remainingSeconds}s`;
        return `${remainingSeconds}s`;
    }

    function formatTotalMinutes(seconds) {
        const minutes = (Number(seconds) || 0) / 60;
        return Number(minutes.toFixed(1)) + " min";
    }

    function formatDurationChips() {
        document.querySelectorAll(".duration-chip").forEach(el => {
            el.innerText = formatDuration(el.dataset.duration);
        });
    }

    function updateSerialNumbers() {
        let rows = document.querySelectorAll("#myTable tbody tr");
        let count = 1;
        rows.forEach(row => {
            if (row.style.display !== "none") {
                let cell = row.querySelector(".si-no");
                if (cell) cell.innerText = count++;
            }
        });
    }

    function searchClass() {
        let input = document.getElementById("myInput").value.toUpperCase();

        document.querySelectorAll(".class-card-wrap").forEach(card => {
            let name = card.dataset.name.toUpperCase();
            card.style.display = name.includes(input) ? "" : "none";
        });

        document.querySelectorAll("#myTable tbody tr").forEach(row => {
            let name = row.querySelector(".class-name").innerText.toUpperCase();
            row.style.display = name.includes(input) ? "" : "none";
        });

        updateSerialNumbers();
    }

    function showGrid() {
        gridView.style.display = "block";
        tableView.style.display = "none";
        gridBtn.classList.add("active");
        tableBtn.classList.remove("active");
    }

    function showTable() {
        gridView.style.display = "none";
        tableView.style.display = "block";
        tableBtn.classList.add("active");
        gridBtn.classList.remove("active");
    }

    function updateStats() {
        let totalSecs = 0;
        let s3 = 0;
        let vdo = 0;

        document.querySelectorAll(".class-card-wrap").forEach(card => {
            totalSecs += Number(card.dataset.duration) || 0;
            if (card.dataset.source === 's3') s3++;
            else vdo++;
        });

        document.getElementById("totalDuration").innerText = formatTotalMinutes(totalSecs);
        document.getElementById("s3Count").innerText = s3;
        document.getElementById("vdoCount").innerText = vdo;
    }

    async function previewVideo(videoId) {
        try {
            if (!videoId) throw new Error('Invalid video ID');
            const res = await fetch('/class-video/' + encodeURIComponent(videoId));
            const data = await res.json();
            if (!data.otp || !data.playbackInfo) {
                alert('Preview failed');
                return;
            }
            const videoFrame = document.getElementById('videoFrame');
            const videoModal = document.getElementById('videoModal');
            const s3Player = document.getElementById('s3VideoPlayer');

            s3Player.pause();
            s3Player.src = '';
            s3Player.style.display = 'none';
            videoFrame.style.display = 'block';
            videoFrame.src = `https://player.vdocipher.com/v2/?otp=${encodeURIComponent(data.otp)}&playbackInfo=${encodeURIComponent(data.playbackInfo)}`;
            videoModal.style.display = 'flex';
        } catch (err) {
            console.error('previewVideo error', err);
            alert('Preview failed');
        }
    }

    function previewS3Video(url) {
        if (!url) {
            alert('No video URL available');
            return;
        }

        try {
            const parsed = new URL(url);
            if (!['https:'].includes(parsed.protocol)) {
                throw new Error('Invalid URL');
            }
        } catch (err) {
            alert('Invalid video source');
            return;
        }

        const s3Player = document.getElementById('s3VideoPlayer');
        const videoFrame = document.getElementById('videoFrame');
        const videoModal = document.getElementById('videoModal');

        videoFrame.style.display = 'none';
        s3Player.style.display = 'block';
        s3Player.src = url;
        videoModal.style.display = 'flex';
    }

    function closeVideo() {
        const videoModal = document.getElementById('videoModal');
        const videoFrame = document.getElementById('videoFrame');
        const s3Player = document.getElementById('s3VideoPlayer');

        videoModal.style.display = 'none';
        videoFrame.src = '';
        videoFrame.style.display = 'block';

        s3Player.pause();
        s3Player.src = '';
        s3Player.style.display = 'none';
    }

    async function deleteClass(chapterCode, classId) {
        const result = await Swal.fire({
            title: "Delete class?",
            text: "Video and resources will be removed from storage",
            icon: "warning",
            showCancelButton: true,
            confirmButtonColor: "#dc3545",
            confirmButtonText: "Delete"
        });

        if (!result.isConfirmed) return;

        const response = await fetch(`/delete-class/${chapterCode}/${classId}`, { method: "POST" });
        if (response.ok) location.reload();
    }

    function watchS3Class(chapterCode, classId) {
        window.location.href = `/watch-class/${chapterCode}/${classId}`;
    }

    function watchVdoClass(chapterCode, classId) {
        window.location.href = `/watch-class/${chapterCode}/${classId}`;
    }

    window.onload = function () {
        formatDurationChips();
        updateSerialNumbers();
        updateStats();
    };
</script>
