<div class="container-fluid mt-4 mb-5">

    <!-- HERO HEADER -->
    <div class="hero-card mb-4">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">

            <div class="d-flex align-items-center gap-3 flex-wrap">

                <a href="/courses" class="hero-back-btn">
                    <i class="fa-solid fa-arrow-left"></i>
                </a>

                <div>
                    <small class="text-light opacity-75 d-block mb-1">
                        Course Students
                    </small>

                    <h2 class="text-white fw-bold m-0">
                        {{courseName}}
                    </h2>

                    <span class="hero-badge mt-2">
                        Student Management
                    </span>
                </div>

            </div>

            <a href="/add-students/{{courseId}}" class="btn btn-light px-4 py-2">
                <i class="fa-solid fa-user-plus me-2"></i>
                Add Student
            </a>

        </div>
    </div>


    <!-- DASHBOARD -->
    <div class="row g-4 mb-4">

        <div class="col-lg-3 col-md-6">
            <div class="stat-card stat-dark">
                <div>
                    <small>Total Students</small>
                    <h2>{{students.length}}</h2>
                </div>
                <i class="fa-solid fa-users stat-icon"></i>
            </div>
        </div>

        <div class="col-lg-3 col-md-6">
            <div class="stat-card stat-green">
                <div>
                    <small>Active</small>
                    <h2 id="activeCount">0</h2>
                </div>
                <i class="fa-solid fa-circle-check stat-icon"></i>
            </div>
        </div>

        <div class="col-lg-3 col-md-6">
            <div class="stat-card stat-red">
                <div>
                    <small>Blocked</small>
                    <h2 id="blockedCount">0</h2>
                </div>
                <i class="fa-solid fa-ban stat-icon"></i>
            </div>
        </div>

        <div class="col-lg-3 col-md-6">
            <div class="stat-card stat-yellow">
                <div>
                    <small>Fees Collected</small>
                    <h2 id="totalCollected">₹0</h2>
                </div>
                <i class="fa-solid fa-indian-rupee-sign stat-icon"></i>
            </div>
        </div>

    </div>


    <!-- SEARCH + TOGGLE -->
    <div class="toolbar-card mb-4">

        <div class="search-box">
            <i class="fa-solid fa-magnifying-glass"></i>
            <input type="text" id="myInput" placeholder="Search student..." onkeyup="searchStudent()">
        </div>

        <div class="view-toggle">
            <button id="gridBtn" class="active" onclick="showGrid()">
                <i class="fa-solid fa-table-cells-large"></i>
            </button>

            <button id="tableBtn" onclick="showTable()">
                <i class="fa-solid fa-table-list"></i>
            </button>
        </div>

    </div>


    <!-- GRID VIEW -->
    <div id="gridView">
        <div class="row g-4">

            {{#each students}}
            <div class="col-xl-3 col-lg-4 col-md-6 student-card-wrap" data-name="{{this.Name}}" id="card-{{this._id}}">
                <div class="student-card">

                    <div class="student-top">

                        <img src="/student-images/{{this._id}}.jpg" class="student-avatar"
                            onerror="this.onerror=null;this.src='/student-images/default-image.jpg';">

                        <span class="status-pill {{#if this.status}}active-pill{{else}}blocked-pill{{/if}}">
                            {{#if this.status}}Active{{else}}Blocked{{/if}}
                        </span>

                    </div>

                    <div class="student-body">

                        <h5 class="fw-bold mb-1">
                            {{this.Name}}
                        </h5>

                        <small class="text-muted d-block mb-3">
                            {{this.Email}}
                        </small>

                        <!-- Progress -->
                        <div class="mb-2 d-flex justify-content-between">
                            <span class="fw-semibold">Progress</span>
                            <strong>
                                {{this.learningProgress.completionPercent}}%
                            </strong>
                        </div>

                        <div class="progress progress-custom mb-3">
                            <div class="progress-bar"
                                style="width:{{this.learningProgress.completionPercent}}%;background:linear-gradient(90deg,var(--brand),#9fd5b2);">
                            </div>
                        </div>

                        <!-- Stats -->
                        <div class="student-meta">

                            <div class="meta-chip blue-chip">
                                🎥
                                {{this.learningProgress.watchedClasses}} /
                                {{this.learningProgress.totalClasses}}
                            </div>

                            <div class="meta-chip pending-chip pending" data-fee="{{this.courseFee}}"
                                data-paid="{{this.Paid_Amount}}">
                                ₹0
                            </div>

                        </div>

                        <small class="text-muted d-block mt-3 mb-3">
                            Last active:
                            <strong>{{this.learningProgress.lastActive}}</strong>
                        </small>
                        <!-- ACTION -->
                        <div class="student-actions">

                            {{#if this.status}}
                            <button class="btn btn-danger btn-sm access-btn"
                                onclick="changeStatus('{{this._id}}', false)">
                                <i class="fa-solid fa-ban me-2 mr-2"></i>
                                Deny Access
                            </button>
                            {{else}}
                            <button class="btn btn-success btn-sm access-btn"
                                onclick="changeStatus('{{this._id}}', true)">
                                <i class="fa-solid fa-circle-check me-2"></i>
                                Approve Access
                            </button>
                            {{/if}}

                            <div class="action-row">
                                <a href="/edit-student/{{this._id}}" class="btn btn-primary btn-sm w-100">
                                    <i class="fa-solid fa-pen me-2"></i>
                                    Edit
                                </a>

                                <button class="btn btn-danger btn-sm w-100" onclick="deleteStudent('{{this._id}}')">
                                    <i class="fa-solid fa-trash me-2"></i>
                                    Delete
                                </button>
                            </div>

                        </div>

                        <style>
                            .student-actions {
                                margin-top: 20px;
                            }

                            .access-btn {
                                height: 48px;
                                border-radius: 14px;
                                margin-bottom: 14px;
                                font-weight: 700;
                                display: flex;
                                align-items: center;
                                justify-content: center;
                            }

                            .action-row {
                                display: flex;
                                gap: 12px;
                            }

                            .action-row .btn {
                                height: 44px;
                                border-radius: 14px;
                                display: flex;
                                align-items: center;
                                justify-content: center;
                            }
                        </style>

                    </div>

                </div>
            </div>
            {{/each}}

        </div>
    </div>


    <!-- TABLE VIEW -->
    <div id="tableView" style="display:none;">
        <div class="table-responsive">

            <table class="table premium-table align-middle" id="myTable">

                <thead>
                    <tr>
                        <th>#</th>
                        <th>Profile</th>
                        <th>Name</th>
                        <th>Paid</th>
                        <th>Pending</th>
                        <th>Progress</th>
                        <th>Watched</th>
                        <th>Last Active</th>
                        <th>Status</th>
                        <th>Access</th>
                        <th>Action</th>
                    </tr>
                </thead>

                <tbody>
                    {{#each students}}
                    <tr id="row-{{this._id}}">

                        <td class="si-no"></td>

                        <td>
                            <img src="/student-images/{{this._id}}.jpg" class="table-avatar"
                                onerror="this.onerror=null;this.src='/student-images/default-image.jpg';">
                        </td>

                        <td class="student-name">
                            <strong>{{this.Name}}</strong>
                            <small class="d-block text-muted">
                                {{this.Email}}
                            </small>
                        </td>

                        <td class="text-success fw-bold">
                            ₹{{this.Paid_Amount}}
                        </td>

                        <td class="pending fw-bold" data-fee="{{this.courseFee}}" data-paid="{{this.Paid_Amount}}">
                        </td>

                        <td style="min-width:180px;">
                            <strong>
                                {{this.learningProgress.completionPercent}}%
                            </strong>

                            <div class="progress mt-2" style="height:10px;border-radius:30px;">
                                <div class="progress-bar"
                                    style="width:{{this.learningProgress.completionPercent}}%;background:linear-gradient(90deg,var(--brand),#9fd5b2);">
                                </div>
                            </div>
                        </td>

                        <td class="fw-bold">
                            {{this.learningProgress.watchedClasses}}
                            /
                            {{this.learningProgress.totalClasses}}
                        </td>

                        <td>
                            {{this.learningProgress.lastActive}}
                        </td>

                        <td>
                            <span class="status-pill {{#if this.status}}active-pill{{else}}blocked-pill{{/if}}">
                                {{#if this.status}}Active{{else}}Blocked{{/if}}
                            </span>
                        </td>

                        <td>
                            {{#if this.status}}
                            <button class="btn btn-danger btn-sm" onclick="changeStatus('{{this._id}}', false)">
                                Deny
                            </button>
                            {{else}}
                            <button class="btn btn-success btn-sm" onclick="changeStatus('{{this._id}}', true)">
                                Approve
                            </button>
                            {{/if}}
                        </td>

                        <td>
                            <a href="/edit-student/{{this._id}}" class="btn btn-primary btn-sm mb-1">
                                Edit
                            </a>

                            <button class="btn btn-danger btn-sm" onclick="deleteStudent('{{this._id}}')">
                                Delete
                            </button>
                        </td>

                    </tr>
                    {{/each}}
                </tbody>

            </table>

        </div>
    </div>


    {{#unless students.length}}
    <div class="empty-box text-center">
        <i class="fa-solid fa-user-graduate"></i>
        <h4>No Students Found</h4>
        <a href="/add-students/{{courseId}}" class="btn btn-success mt-2">
            Add First Student
        </a>
    </div>
    {{/unless}}

</div>


<style>
    .hero-card {
        background: linear-gradient(135deg, var(--brand), var(--brand-2));
        border-radius: 28px;
        padding: 32px;
        box-shadow: 0 18px 40px rgba(18, 49, 76, .22);
    }

    .hero-back-btn {
        width: 52px;
        height: 52px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(255, 255, 255, .18);
        color: var(--surface);
        text-decoration: none;
        font-size: 20px;
    }

    .hero-badge {
        display: inline-block;
        padding: 7px 14px;
        border-radius: 12px;
        background: rgba(255, 255, 255, .16);
        color: var(--surface);
        font-size: 13px;
        font-weight: 600;
    }

    .stat-card {
        border-radius: 22px;
        padding: 28px;
        color: var(--surface);
        display: flex;
        justify-content: space-between;
        align-items: center;
        box-shadow: 0 12px 30px rgba(0, 0, 0, .08);
    }

    .stat-dark {
        background: linear-gradient(135deg, var(--brand), #0b2237);
    }

    .stat-green {
        background: linear-gradient(135deg, #9fd5b2, #70bf8e);
    }

    .stat-red {
        background: linear-gradient(135deg, #ff8a8a, #dc3545);
    }

    .stat-yellow {
        background: linear-gradient(135deg, #ffd54f, #f6b300);
        color: #222;
    }

    .stat-icon {
        font-size: 34px;
    }

    .toolbar-card {
        background: var(--surface);
        padding: 18px;
        border-radius: 18px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 20px;
        box-shadow: 0 8px 25px rgba(0, 0, 0, .06);
    }

    .search-box {
        flex: 1;
        display: flex;
        align-items: center;
        gap: 12px;
        background: #f7f9fc;
        padding: 14px 18px;
        border-radius: 14px;
    }

    .search-box input {
        border: none;
        background: none;
        width: 100%;
        outline: none;
    }

    .view-toggle {
        display: flex;
        gap: 10px;
    }

    .view-toggle button {
        width: 50px;
        height: 50px;
        border: none;
        border-radius: 12px;
        background: #edf2f7;
    }

    .view-toggle button.active {
        background: var(--brand);
        color: var(--surface);
    }

    .student-card {
        background: var(--surface);
        border-radius: 24px;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(0, 0, 0, .06);
        transition: .25s;
        height: 100%;
    }

    .student-card:hover {
        transform: translateY(-6px);
    }

    .student-top {
        padding: 25px;
        text-align: center;
        background: var(--surface-2);
    }

    .student-avatar {
        width: 95px;
        height: 95px;
        border-radius: 50%;
        object-fit: cover;
        margin-bottom: 14px;
        border: 4px solid var(--surface);
        box-shadow: 0 10px 25px rgba(0, 0, 0, .08);
    }

    .student-body {
        padding: 22px;
    }

    .status-pill {
        display: inline-block;
        padding: 6px 14px;
        border-radius: 30px;
        font-size: 12px;
        font-weight: 700;
    }

    .active-pill {
        background: #dff7e7;
        color: #198754;
    }

    .blocked-pill {
        background: #ffe3e3;
        color: #dc3545;
    }

    .progress-custom {
        height: 10px;
        border-radius: 30px;
        background: #edf2f7;
    }

    .student-meta {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

    .meta-chip {
        padding: 8px 14px;
        border-radius: 12px;
        font-size: 13px;
        font-weight: 600;
    }

    .blue-chip {
        background: #e6f0ff;
        color: var(--brand);
    }

    .pending-chip {
        background: #fff1f1;
        color: #dc3545;
    }

    .premium-table {
        background: var(--surface);
        border-radius: 18px;
        overflow: hidden;
    }

    .premium-table thead {
        background: var(--brand);
        color: var(--surface);
    }

    .premium-table th,
    .premium-table td {
        padding: 18px;
    }

    .table-avatar {
        width: 55px;
        height: 55px;
        border-radius: 50%;
        object-fit: cover;
    }

    .empty-box {
        background: var(--surface);
        padding: 70px 20px;
        border-radius: 24px;
    }

    .empty-box i {
        font-size: 55px;
        color: var(--brand);
        margin-bottom: 20px;
    }

    @media(max-width:768px) {

        .hero-card,
        .toolbar-card {
            padding: 20px;
        }

        .toolbar-card {
            flex-direction: column;
        }
    }
</style>


<script>
    function updateSerialNumbers() {
        let rows = document.querySelectorAll("#myTable tbody tr");
        let count = 1;

        rows.forEach(row => {
            if (row.style.display !== "none") {
                row.querySelector(".si-no").innerText = count++;
            }
        });
    }

    function searchStudent() {
        let input = document.getElementById("myInput").value.toUpperCase();

        document.querySelectorAll(".student-card-wrap").forEach(card => {
            let name = card.dataset.name.toUpperCase();
            card.style.display = name.includes(input) ? "" : "none";
        });

        document.querySelectorAll("#myTable tbody tr").forEach(row => {
            let name = row.querySelector(".student-name").innerText.toUpperCase();
            row.style.display = name.includes(input) ? "" : "none";
        });

        updateSerialNumbers();
    }

    function showGrid() {
        document.getElementById("gridView").style.display = "block";
        document.getElementById("tableView").style.display = "none";

        gridBtn.classList.add("active");
        tableBtn.classList.remove("active");
    }

    function showTable() {
        document.getElementById("gridView").style.display = "none";
        document.getElementById("tableView").style.display = "block";

        tableBtn.classList.add("active");
        gridBtn.classList.remove("active");
    }
    function calculatePendingFees() {
        let cells = document.querySelectorAll(".pending");

        cells.forEach(cell => {
            let fee = Number(cell.dataset.fee) || 0;
            let paid = Number(cell.dataset.paid) || 0;
            let balance = fee - paid;

            cell.innerText = "₹" + balance.toLocaleString('en-IN');

            // reset
            cell.classList.remove("paid-chip", "unpaid-chip");

            if (balance <= 0) {
                cell.classList.add("paid-chip");
            } else {
                cell.classList.add("unpaid-chip");
            }
        });
    }

    function updateDashboard() {
        let rows = document.querySelectorAll("#myTable tbody tr");

        let active = 0;
        let blocked = 0;
        let total = 0;

        rows.forEach(row => {
            if (row.innerHTML.includes("Active")) active++;
            if (row.innerHTML.includes("Blocked")) blocked++;

            total += Number(
                row.querySelector(".pending").dataset.paid
            ) || 0;
        });

        document.getElementById("activeCount").innerText = active;
        document.getElementById("blockedCount").innerText = blocked;
        document.getElementById("totalCollected").innerText =
            "₹" + total.toLocaleString('en-IN');
    }

    function changeStatus(studentId, status) {

        Swal.fire({
            title: status ? "Approve access?" : "Block access?",
            icon: "question",
            showCancelButton: true,
            confirmButtonText: "Confirm"
        }).then(result => {

            if (!result.isConfirmed) return;

            fetch('/change-status/' + studentId + '/' + status, { method: 'POST' })
                .then(res => { if(!res.ok) throw new Error("Network error"); return res.json(); })
                .then(data => {
                    if (data.status) {
                        location.reload();
                    }
                });

        });
    }

    function deleteStudent(id) {

        Swal.fire({
            title: "Delete student?",
            text: "This action cannot be undone",
            icon: "warning",
            showCancelButton: true,
            confirmButtonColor: "#dc3545",
            confirmButtonText: "Delete"
        }).then(result => {

            if (!result.isConfirmed) return;

            fetch('/delete-student/' + id, {
                method: 'POST'
            })
                .then(res => { if(!res.ok) throw new Error("Network error"); return res.json(); })
                .then(data => {

                    if (data.success) {

                        let row = document.getElementById("row-" + id);
                        let card = document.getElementById("card-" + id);

                        if (row) row.remove();
                        if (card) card.remove();

                        updateSerialNumbers();
                        updateDashboard();

                        Swal.fire("Deleted!", "", "success");
                    }

                });

        });
    }

    window.onload = function () {
        updateSerialNumbers();
        calculatePendingFees();
        updateDashboard();
    };
</script>
