<section class="container-fluid mt-4 mb-5">

    <div class="row justify-content-center">
        <div class="col-xl-9 col-lg-10">

            <div class="card border-0 shadow-lg add-student-card">

                <!-- Header -->
                <div class="card-header student-header border-0">
                    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">

                        <div>
                            <h2 class="m-0 fw-bold text-white">
                                Add Student
                            </h2>
                            <small class="text-light opacity-75">
                                Register a new learner to Zeitnah Academy
                            </small>
                        </div>

                        <a href="/students" class="btn btn-light back-btn">
                            <i class="fa-solid fa-arrow-left me-2"></i>
                            Back
                        </a>

                    </div>
                </div>

                <div class="card-body p-4 p-lg-5">

                    <form
                        action="/add-students"
                        method="POST"
                        enctype="multipart/form-data"
                        id="studentForm"
                    >

                        <input
                            type="hidden"
                            name="redirectCourseId"
                            value="{{selectedCourseId}}"
                        >

                        <div class="row g-4">

                            <!-- LEFT -->
                            <div class="col-lg-8">

                                <div class="mb-4">
                                    <label class="form-label fw-semibold">
                                        Full Name
                                    </label>

                                    <input
                                        type="text"
                                        class="form-control custom-input"
                                        placeholder="Enter full name"
                                        name="name"
                                        id="studentName"
                                        required
                                    >
                                </div>

                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="mb-4">
                                            <label class="form-label fw-semibold">
                                                Email Address
                                            </label>

                                            <input
                                                type="email"
                                                class="form-control custom-input"
                                                placeholder="name@example.com"
                                                name="email"
                                                required
                                            >

                                            <small class="text-muted mt-2 d-block">
                                                If email already exists, selected course will be added.
                                            </small>
                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        <div class="mb-4">
                                            <label class="form-label fw-semibold">
                                                Phone Number
                                            </label>

                                            <input
                                                type="tel"
                                                class="form-control custom-input"
                                                placeholder="Enter 10 digit number"
                                                name="Phone_Number"
                                                pattern="[0-9]{10}"
                                                maxlength="10"
                                                required
                                            >
                                        </div>
                                    </div>
                                </div>

                                <div class="mb-4">
                                    <label class="form-label fw-semibold">
                                        Select Course
                                    </label>

                                    <select
                                        class="form-control custom-input"
                                        name="package"
                                        required
                                        id="courseSelect"
                                        multiple
                                    >
                                        <option value="">
                                            Choose Course...
                                        </option>

                                        {{#each courses}}
                                        <option
                                            value="{{this._id}}"
                                            data-fee="{{this.Total_Fees}}"
                                            {{selected this._id ../selectedCourseId}}
                                        >
                                            {{this.name}}
                                        </option>
                                        {{/each}}
                                    </select>
                                </div>

                                <div class="mb-4">
                                    <label class="form-label fw-semibold">
                                        Amount Paid
                                    </label>

                                    <input
                                        type="number"
                                        class="form-control custom-input"
                                        placeholder="Enter paid amount"
                                        name="Paid_Amount"
                                        id="paidAmount"
                                        required
                                    >
                                </div>

                            </div>

                            <!-- RIGHT -->
                            <div class="col-lg-4">

                                <div class="profile-box text-center mb-4">

                                    <img
                                        id="preview"
                                        src="/img/placeholders/profile.svg"
                                        class="student-preview"
                                    >

                                    <h6
                                        class="mt-3 mb-1 fw-bold"
                                        id="studentPreviewName"
                                    >
                                        Student Name
                                    </h6>

                                    <small class="text-muted">
                                        Profile Preview
                                    </small>

                                    <label class="upload-btn mt-3">
                                        <i class="fa-solid fa-camera me-2"></i>
                                        Upload Photo

                                        <input
                                            type="file"
                                            name="image"
                                            hidden
                                            accept="image/*"
                                            onchange="previewImage(event)"
                                        >
                                    </label>

                                </div>

                                <div class="summary-card">

                                    <h6 class="fw-bold mb-3">
                                        Payment Summary
                                    </h6>

                                    <div class="summary-row">
                                        <span>Course Fee</span>
                                        <strong id="courseFee">₹0</strong>
                                    </div>

                                    <div class="summary-row">
                                        <span>Paid</span>
                                        <strong id="paidPreview">₹0</strong>
                                    </div>

                                    <hr>

                                    <div class="summary-row">
                                        <span>Balance</span>
                                        <strong
                                            id="balancePreview"
                                            class="text-danger"
                                        >
                                            ₹0
                                        </strong>
                                    </div>

                                </div>

                            </div>

                        </div>

                        <!-- DATES -->
                        <div class="row mt-2 g-3">

                            <div class="col-md-4">
                                <label class="form-label fw-semibold">
                                    Start Date
                                </label>

                                <input
                                    id="startDate"
                                    class="form-control custom-input"
                                    type="date"
                                    name="Start_Date"
                                    required
                                >
                            </div>

                            <div class="col-md-4">
                                <label class="form-label fw-semibold">
                                    End Date
                                </label>

                                <input
                                    id="endDate"
                                    class="form-control custom-input"
                                    type="date"
                                    name="End_Date"
                                    required
                                    disabled
                                >
                            </div>

                            <div class="col-md-4">
                                <label class="form-label fw-semibold">
                                    Duration
                                </label>

                                <input
                                    type="text"
                                    class="form-control custom-input bg-light"
                                    id="duration"
                                    name="Duration"
                                    readonly
                                    placeholder="Auto calculated"
                                >
                            </div>

                        </div>

                        <!-- Buttons -->
                        <div class="text-center mt-5">
                            <button
                                type="submit"
                                class="btn btn-success px-5 py-2 me-2 action-btn"
                            >
                                <i class="fa-solid fa-check me-2"></i>
                                Save Student
                            </button>

                            <button
                                type="reset"
                                class="btn btn-secondary px-5 py-2 action-btn"
                                onclick="resetFormExtras()"
                            >
                                Reset
                            </button>
                        </div>

                    </form>

                </div>
            </div>

        </div>
    </div>

</section>

<style>
.add-student-card{
    border-radius:24px;
    overflow:hidden;
}

.student-header{
    background:linear-gradient(
        135deg,
        var(--brand),
        var(--brand-2)
    );
    padding:28px 32px;
}

.student-header h2 {
    color: white !important;
}

.custom-input{
    border-radius:12px;
    min-height:50px;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text);
    padding:12px 16px;
    transition: all 0.25s ease;
}

.custom-input:focus{
    border-color:var(--brand);
    background: var(--card-solid);
    box-shadow: 0 0 0 4px var(--shadow-brand) !important;
}

.profile-box,
.summary-card{
    background:var(--surface-2);
    border: 1px solid var(--border);
    border-radius:20px;
    padding:24px;
}

.student-preview{
    width:130px;
    height:130px;
    border-radius:50%;
    object-fit:cover;
    border:4px solid var(--surface);
    box-shadow:var(--shadow);
}

.upload-btn{
    display:inline-block;
    padding:10px 20px;
    border-radius:12px;
    background:linear-gradient(135deg, var(--brand), var(--brand-2));
    color:var(--btn-primary-text) !important;
    cursor:pointer;
    font-weight:600;
    transition:all 0.2s ease;
    box-shadow: 0 4px 12px var(--shadow-brand);
}

.upload-btn:hover{
    transform:translateY(-1px);
    box-shadow: 0 6px 16px var(--shadow-brand);
}

.summary-row{
    display:flex;
    justify-content:space-between;
    margin-bottom:12px;
    font-size:15px;
}

.back-btn,
.action-btn{
    border-radius:12px;
}
</style>

<script>
const startDate=document.getElementById("startDate");
const endDate=document.getElementById("endDate");
const duration=document.getElementById("duration");
const courseSelect=document.getElementById("courseSelect");
const paidAmount=document.getElementById("paidAmount");
const studentName=document.getElementById("studentName");

function previewImage(e){
    const file=e.target.files[0];
    if(!file) return;

    const url=URL.createObjectURL(file);
    preview.src=url;
    preview.onload=()=>URL.revokeObjectURL(url);
}

studentName.addEventListener("input",()=>{
    studentPreviewName.innerText=
        studentName.value || "Student Name";
});

function calculateDuration(){
    if(startDate.value && endDate.value){

        const start=new Date(startDate.value);
        const end=new Date(endDate.value);

        const diff=end-start;
        const days=
            Math.floor(
                diff/(1000*60*60*24)
            ) + 1;

        duration.value =
            days > 0
            ? (days===1 ? "1 day" : days+" days")
            : "";
    }
}

function updateFeePreview(){

    let fee = 0;
    for (let i = 0; i < courseSelect.options.length; i++) {
        const option = courseSelect.options[i];
        if (option.selected && option.value) {
            fee += Number(option.dataset.fee || 0);
        }
    }

    let paid = Number(paidAmount.value || 0);

    if (paid > fee) {
        paid = fee;
        paidAmount.value = fee;
    }

    if (paid < 0) {
        paid = 0;
        paidAmount.value = 0;
    }

    const balance=fee-paid;

    courseFee.innerText=
        "₹"+fee.toLocaleString("en-IN");

    paidPreview.innerText=
        "₹"+paid.toLocaleString("en-IN");

    balancePreview.innerText=
        "₹"+balance.toLocaleString("en-IN");
}

function resetFormExtras(){

    duration.value="";
    endDate.value="";
    endDate.disabled=true;
    paidAmount.value="";

    preview.src=
        "/img/placeholders/profile.svg";

    studentPreviewName.innerText=
        "Student Name";

    courseFee.innerText="₹0";
    paidPreview.innerText="₹0";
    balancePreview.innerText="₹0";
}

startDate.addEventListener("change",function(){
    endDate.disabled=false;
    endDate.min=this.value;

    if(endDate.value < this.value){
        endDate.value="";
    }

    calculateDuration();
});

endDate.addEventListener(
    "change",
    calculateDuration
);

courseSelect.addEventListener(
    "change",
    updateFeePreview
);

paidAmount.addEventListener(
    "input",
    updateFeePreview
);

paidAmount.addEventListener(
    "keyup",
    updateFeePreview
);

paidAmount.addEventListener(
    "change",
    updateFeePreview
);

document.getElementById("studentForm").addEventListener("submit", function(e) {
    let fee = 0;
    for (let i = 0; i < courseSelect.options.length; i++) {
        const option = courseSelect.options[i];
        if (option.selected && option.value) {
            fee += Number(option.dataset.fee || 0);
        }
    }
    let paid = Number(paidAmount.value || 0);
    if (paid > fee) {
        paidAmount.value = fee;
    }
    if (paid < 0) {
        paidAmount.value = 0;
    }
});

window.addEventListener(
    "load",
    updateFeePreview
);
</script>
