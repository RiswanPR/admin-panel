<!doctype html>
<html lang="en">

<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="description" content="Zeitnah Academy Admin Dashboard">
  <meta name="theme-color" content="#0b1220" id="themeMeta">

  <title>Zeitnah Academy</title>

  <link class="brand-favicon" rel="icon" type="image/png" href="/images/logo.png">

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
    rel="stylesheet">

  <!-- Bootstrap -->
  <link rel="stylesheet" href="/stylesheets/css/bootstrap.min.css">

  <!-- Icons -->
  <link rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

  <!-- SweetAlert -->
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

  <style>
    :root {
      --bg: #f4f6fa;
      --surface: rgba(255, 255, 255, 0.95);
      --surface-2: rgba(241, 245, 249, 0.7);
      --card: rgba(255, 255, 255, 0.85);
      --card-solid: #ffffff;

      --text: #12314c;
      --muted: #506e8b;
      --border: rgba(18, 49, 76, 0.12);

      --brand: #12314c;
      --brand-2: #1d4e89;

      --green: #9fd5b2;
      --yellow: #f6ed4a;
      --red: #dc3545;

      --shadow: 0 10px 25px -5px rgba(18, 49, 76, 0.04), 0 8px 10px -6px rgba(18, 49, 76, 0.04);
      --shadow-glow: 0 0 20px rgba(159, 213, 178, 0.2);
      --shadow-brand: rgba(18, 49, 76, 0.15);
      --radius: 20px;

      --btn-primary-text: #ffffff;
    }

    html[data-theme="dark"] {
      --bg: #0a111a;
      --surface: rgba(18, 28, 41, 0.95);
      --surface-2: rgba(23, 37, 54, 0.6);
      --card: rgba(18, 28, 41, 0.85);
      --card-solid: #121c29;

      --text: #ffffff;
      --muted: #8fa5ba;
      --border: rgba(159, 213, 178, 0.18);

      --brand: #9fd5b2;
      --brand-2: #70bf8e;

      --green: #9fd5b2;
      --yellow: #f6ed4a;
      --red: #f87171;

      --shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.35), 0 10px 10px -10px rgba(0, 0, 0, 0.35);
      --shadow-glow: 0 0 25px rgba(159, 213, 178, 0.25);
      --shadow-brand: rgba(159, 213, 178, 0.2);

      --btn-primary-text: #12314c;
    }

    * {
      box-sizing: border-box;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      margin: 0;
      padding: 0;
      font-family: 'Inter', sans-serif;
      background: radial-gradient(at 0% 0%, rgba(159, 213, 178, 0.08) 0px, transparent 50%), radial-gradient(at 50% 0%, rgba(18, 49, 76, 0.05) 0px, transparent 50%), var(--bg);
      background-attachment: fixed;
      color: var(--text);
      min-height: 100vh;
      overflow-x: hidden;
      transition: background-color 0.3s ease, color 0.3s ease;
    }

    a {
      text-decoration: none;
      color: inherit;
    }

    img {
      max-width: 100%;
      display: block;
    }

    main {
      min-height: 100vh;
      transition: .25s ease;
    }

    /* Cards */
    .card {
      border: 1px solid var(--border) !important;
      border-radius: var(--radius);
      background: var(--card);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      color: var(--text);
      box-shadow: var(--shadow);
      transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.3s cubic-bezier(0.4, 0, 0.2, 1), border-color 0.3s ease;
    }

    /* Interactive animations for list cards */
    .student-card,
    .course-card {
      background: var(--card) !important;
      border: 1px solid var(--border) !important;
      border-radius: 22px;
      overflow: hidden;
      transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.3s cubic-bezier(0.4, 0, 0.2, 1), border-color 0.3s ease !important;
    }

    .student-card:hover,
    .course-card:hover {
      transform: translateY(-5px);
      box-shadow: var(--shadow), var(--shadow-glow) !important;
      border-color: rgba(159, 213, 178, 0.3) !important;
    }

    /* Buttons */
    .btn {
      border-radius: 12px;
      font-weight: 600;
      padding: 10px 22px;
      transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
      border: none;
      letter-spacing: 0.2px;
    }

    .btn:hover {
      transform: translateY(-1px);
    }

    .btn:active {
      transform: translateY(1px);
    }

    .btn-success {
      background: linear-gradient(135deg, var(--green), #86c49c);
      color: #12314c !important;
      box-shadow: 0 4px 12px rgba(159, 213, 178, 0.2);
    }

    .btn-success:hover {
      background: linear-gradient(135deg, #86c49c, #70bf8e);
      box-shadow: 0 6px 18px rgba(159, 213, 178, 0.35);
    }

    .btn-primary {
      background: linear-gradient(135deg, var(--brand), var(--brand-2));
      color: var(--btn-primary-text) !important;
      box-shadow: 0 4px 12px var(--shadow-brand);
    }

    .btn-primary:hover {
      box-shadow: 0 6px 18px var(--shadow-brand);
      filter: brightness(1.05);
    }

    .btn-warning {
      background: linear-gradient(135deg, var(--yellow), #e1d839);
      color: #12314c !important;
      box-shadow: 0 4px 12px rgba(246, 237, 74, 0.2);
    }

    .btn-warning:hover {
      background: linear-gradient(135deg, #e1d839, #cbc22b);
      box-shadow: 0 6px 18px rgba(246, 237, 74, 0.35);
    }

    .btn-danger {
      background: linear-gradient(135deg, var(--red), #dc2626);
      color: white !important;
      box-shadow: 0 4px 12px rgba(239, 68, 68, 0.2);
    }

    .btn-danger:hover {
      background: linear-gradient(135deg, #dc2626, #b91c1c);
      box-shadow: 0 6px 18px rgba(239, 68, 68, 0.35);
    }

    /* Tables */
    .table-responsive {
      border-radius: 16px;
      border: 1px solid var(--border);
      background: var(--surface);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      box-shadow: var(--shadow);
      overflow: hidden;
      margin-bottom: 24px;
    }

    .table {
      margin-bottom: 0;
      color: var(--text);
      background: transparent !important;
      border-collapse: separate;
    }

    .table thead {
      background: var(--surface-2);
    }

    .table th {
      border-bottom: 1px solid var(--border) !important;
      color: var(--muted);
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.8px;
      padding: 16px 20px;
    }

    .table td {
      border-bottom: 1px solid var(--border) !important;
      padding: 16px 20px;
      color: var(--text);
      transition: background-color 0.2s ease;
    }

    .table tr:last-child td {
      border-bottom: none !important;
    }

    .table tbody tr:hover td {
      background-color: var(--surface-2) !important;
    }

    /* Forms */
    .form-control,
    .form-select,
    textarea {
      border-radius: 12px;
      min-height: 48px;
      border: 1px solid var(--border);
      background: var(--surface);
      color: var(--text);
      padding: 10px 16px;
      box-shadow: none !important;
      transition: border-color 0.2s ease, box-shadow 0.2s ease, background-color 0.2s ease;
    }

    textarea {
      min-height: auto;
    }

    .form-control::placeholder,
    textarea::placeholder {
      color: var(--muted);
      opacity: 0.7;
    }

    .form-control:focus,
    .form-select:focus,
    textarea:focus {
      border-color: var(--brand);
      background: var(--card-solid);
      color: var(--text);
      box-shadow: 0 0 0 4px var(--shadow-brand) !important;
    }

    /* Dropdowns */
    .dropdown-menu {
      background: var(--surface);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border: 1px solid var(--border);
      border-radius: 14px;
      box-shadow: var(--shadow);
      padding: 6px;
    }

    .dropdown-item {
      color: var(--text);
      border-radius: 8px;
      padding: 8px 16px;
      font-weight: 500;
      transition: all 0.2s ease;
    }

    .dropdown-item:hover {
      background: var(--surface-2);
      color: var(--brand);
      transform: translateX(2px);
    }

    /* Modals */
    .modal-content {
      background: var(--surface);
      backdrop-filter: blur(25px);
      -webkit-backdrop-filter: blur(25px);
      color: var(--text);
      border: 1px solid var(--border);
      border-radius: 22px;
      box-shadow: var(--shadow);
    }

    .badge {
      border-radius: 10px;
      padding: 6px 12px;
      font-weight: 600;
      font-size: 11px;
      letter-spacing: 0.3px;
    }

    /* Custom Chips & Badges */
    .paid-chip {
      color: #065f46 !important;
      background: rgba(159, 213, 178, 0.2) !important;
      border: 1px solid rgba(159, 213, 178, 0.35) !important;
    }

    html[data-theme="dark"] .paid-chip {
      color: var(--green) !important;
      background: rgba(159, 213, 178, 0.1) !important;
      border: 1px solid rgba(159, 213, 178, 0.2) !important;
    }

    .unpaid-chip {
      color: var(--red) !important;
      background: rgba(239, 68, 68, 0.12) !important;
      border: 1px solid rgba(239, 68, 68, 0.2) !important;
    }

    /* Premium components styling */
    .search-box,
    .toolbar-card,
    .top-search input {
      background: var(--surface) !important;
      color: var(--text) !important;
      border: 1px solid var(--border) !important;
    }

    .search-box input,
    .top-search input::placeholder {
      color: var(--muted) !important;
    }

    .view-toggle button {
      background: var(--surface) !important;
      color: var(--muted) !important;
      border: 1px solid var(--border) !important;
      transition: all 0.2s ease;
    }

    .view-toggle button.active {
      background: linear-gradient(135deg, var(--brand), var(--brand-2)) !important;
      color: var(--btn-primary-text) !important;
      border: none !important;
      box-shadow: 0 4px 10px var(--shadow-brand) !important;
    }

    .course-chip,
    .meta-chip,
    .blue-chip {
      background: var(--surface-2) !important;
      color: var(--text) !important;
      border: 1px solid var(--border) !important;
    }

    .active-pill {
      background: rgba(159, 213, 178, 0.2) !important;
      color: #065f46 !important;
      border: 1px solid rgba(159, 213, 178, 0.35);
    }

    html[data-theme="dark"] .active-pill {
      background: rgba(159, 213, 178, 0.12) !important;
      color: var(--green) !important;
      border: 1px solid rgba(159, 213, 178, 0.2);
    }

    .blocked-pill {
      background: rgba(239, 68, 68, 0.12) !important;
      color: var(--red) !important;
      border: 1px solid rgba(239, 68, 68, 0.15);
    }

    .text-muted {
      color: var(--muted) !important;
    }

    /* Bootstrap overrides */
    .bg-white,
    .bg-light {
      background: var(--surface) !important;
      color: var(--text) !important;
    }

    .text-dark {
      color: var(--text) !important;
    }

    .border {
      border-color: var(--border) !important;
    }

    .alert {
      border: 1px solid rgba(255, 255, 255, 0.05);
      border-radius: 14px;
    }

    /* Scrollbars */
    ::-webkit-scrollbar {
      width: 8px;
      height: 8px;
    }

    ::-webkit-scrollbar-track {
      background: transparent;
    }

    ::-webkit-scrollbar-thumb {
      background: var(--border);
      border-radius: 10px;
    }

    ::-webkit-scrollbar-thumb:hover {
      background: var(--muted);
    }

    .page-fade {
      animation: fadeIn .3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    @keyframes fadeIn {
      from {
        opacity: 0;
        transform: translateY(6px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
  </style>

  <script>
    (() => {
      const savedTheme = localStorage.getItem("zeitnah-theme") || "dark";
      let activeTheme = savedTheme;
      
      if (savedTheme === "auto") {
        activeTheme = window.matchMedia('(prefers-color-scheme: dark)').matches ? "dark" : "light";
      }
      
      document.documentElement.setAttribute("data-theme", activeTheme);

      window.addEventListener("DOMContentLoaded", () => {
        document.getElementById("themeMeta").content =
          activeTheme === "dark" ? "#0b1220" : "#f6f8fb";
      });
    })();

    function toggleTheme(){
      let current = document.documentElement.getAttribute("data-theme");
      if (current === "auto") {
        current = window.matchMedia('(prefers-color-scheme: dark)').matches ? "dark" : "light";
      }
      const next = current === "dark" ? "light" : "dark";

      document.documentElement.setAttribute("data-theme", next);
      localStorage.setItem("zeitnah-theme", next);

      document.getElementById("themeMeta").content =
        next === "dark" ? "#0b1220" : "#f6f8fb";

      const switcher = document.getElementById("themeSwitch");
      if(switcher) switcher.checked = next === "light";
    }
  </script>
</head>

<body>

  {{#if admins}}
    {{>Admin-Header}}
  {{/if}}

  {{#if teacherPanel}}
    {{>Teacher-Header}}
  {{/if}}

  <main class="page-fade">
    {{{body}}}
  </main>

  <script src="/javascripts/jquery/jquery-2.2.4.min.js"></script>
  <script src="/javascripts/popper.min.js"></script>
  <script src="/javascripts/bootstrap.min.js"></script>

  <script>
    (function () {
      const blockShortcut = (e) => {
        const key = e.key?.toLowerCase();
        if (e.key === 'F12') return true;
        if ((e.ctrlKey || e.metaKey) && e.shiftKey && ['i', 'j', 'c', 'p'].includes(key)) return true;
        if ((e.ctrlKey || e.metaKey) && ['u', 's'].includes(key)) return true;
        return false;
      };

      document.addEventListener('keydown', function (e) {
        if (blockShortcut(e)) {
          e.preventDefault();
          e.stopPropagation();
          return false;
        }
      }, true);

      document.addEventListener('contextmenu', function (e) {
        e.preventDefault();
        return false;
      }, true);
    })();
  </script>

</body>
</html>